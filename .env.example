# Application
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://xch_user:xch_password@localhost:5432/xch_db
POSTGRES_USER=xch_user
POSTGRES_PASSWORD=xch_password
POSTGRES_DB=xch_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=xch-storage

# JWT
JWT_SECRET=change_this_to_a_random_secret_key_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Default Tenant (MVP - single tenant)
DEFAULT_TENANT_ID=tenant_default
DEFAULT_TENANT_NAME=Délégation Île-de-France
DEFAULT_TENANT_SUBDOMAIN=idf

# Default Admin User
ADMIN_EMAIL=admin@xch.local
ADMIN_PASSWORD=admin
ADMIN_NAME=Administrateur

# OIDC (optional - disable by default)
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:3001/auth/oidc/callback

# Integrations (optional)
NETBOX_ENABLED=false
NETBOX_URL=
NETBOX_TOKEN=

UPTIME_KUMA_ENABLED=false
UPTIME_KUMA_URL=
UPTIME_KUMA_TOKEN=

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/heic
ALLOWED_DOCUMENT_TYPES=application/pdf

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Sentry (Error Tracking - optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Email (for notifications - optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@xch.local
