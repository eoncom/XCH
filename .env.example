# ============================================================================
# XCH - Docker Compose Environment Variables
# ============================================================================
# Copy this file to .env and adjust values for your environment

# ===== DATABASE (PostgreSQL) =====
POSTGRES_USER=xch_user
POSTGRES_PASSWORD=XchSecure2024!
POSTGRES_DB=xch_dev
POSTGRES_PORT=5433

# ===== REDIS =====
REDIS_PORT=6380

# ===== MINIO (S3-compatible storage) =====
MINIO_ACCESS_KEY=xch_minio_admin
MINIO_SECRET_KEY=XchMinIO2024SecureKey!
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ===== FRONTEND URLs (used by docker-compose.yml) =====
# URL where the backend API is accessible (from frontend perspective)
FRONTEND_API_URL=http://localhost:3002
# URL where the frontend is accessible
FRONTEND_APP_URL=http://localhost:3001

# ============================================================================
# ADDITIONAL CONFIGURATION (for reference - set in backend/.env and frontend/.env.local)
# ============================================================================

# Backend Configuration (see backend/.env.example for full list)
# - DATABASE_URL: Connection string for PostgreSQL
# - JWT_SECRET: Secret key for JWT tokens (min 32 chars)
# - CORS_ORIGINS: Comma-separated list of allowed origins
# - COOKIE_DOMAIN: Domain for cookies (empty for localhost)
# - FRONTEND_URL: URL of frontend application

# Frontend Configuration (see frontend/.env.example for full list)
# - NEXT_PUBLIC_API_URL: URL to backend API
# - NEXT_PUBLIC_APP_URL: URL of this frontend

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# 1. Change ALL passwords and secrets (POSTGRES_PASSWORD, MINIO_SECRET_KEY, JWT_SECRET)
# 2. Set FRONTEND_API_URL to production backend domain (e.g., https://api.yourdomain.com)
# 3. Set FRONTEND_APP_URL to production frontend domain (e.g., https://app.yourdomain.com)
# 4. Configure backend/.env with:
#    - Production DATABASE_URL
#    - Strong JWT_SECRET (min 32 random characters)
#    - CORS_ORIGINS with production domains
#    - COOKIE_DOMAIN (e.g., .yourdomain.com)
#    - NODE_ENV=production
# 5. Configure frontend/.env.local with:
#    - Production NEXT_PUBLIC_API_URL
#    - Production NEXT_PUBLIC_APP_URL
# 6. Enable SSL/TLS certificates (Nginx reverse proxy)
# 7. Configure firewall rules (UFW)
# 8. Set up backup strategy for PostgreSQL volumes
