# ============================================================================
# XCH - Docker Compose Environment Variables
# ============================================================================
# Copy this file to .env and adjust values for your environment
#
# ARCHITECTURE:
#   All traffic goes through Nginx on ports 80/443:
#     /         → frontend:3001
#     /api/     → backend:3000
#     /storage/ → minio:9000
#
#   In development mode (docker-compose.override.yml auto-loaded):
#     Direct access to services on their ports for debugging
#
#   In production mode (skip overrides):
#     docker-compose -f docker-compose.yml up -d

# ===== DATABASE (PostgreSQL) =====
POSTGRES_USER=xch_user
# Generate a strong password : `openssl rand -base64 32`
# Compose docker-compose.yml fails fast (`:?`) if this is missing.
POSTGRES_PASSWORD=
POSTGRES_DB=xch_dev

# Dev override ports (only used by docker-compose.override.yml)
POSTGRES_PORT=5433

# ===== REDIS =====
# Dev override port
REDIS_PORT=6380

# ===== MINIO (S3-compatible storage) =====
MINIO_ACCESS_KEY=xch_minio_admin
# Generate a strong key : `openssl rand -base64 40`
# Compose docker-compose.yml fails fast (`:?`) if this is missing.
MINIO_SECRET_KEY=
# Dev override ports
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ===== NGINX =====
# Ports exposed by the Nginx reverse proxy
HTTP_PORT=80
HTTPS_PORT=443

# ===== FRONTEND =====
# Leave empty for single-origin deployment (nginx proxy)
# Set only if frontend and API are on different domains
FRONTEND_API_URL=
FRONTEND_APP_URL=

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# 1. Change ALL passwords and secrets (POSTGRES_PASSWORD, MINIO_SECRET_KEY)
# 2. Set strong JWT_SECRET in backend/.env (min 32 random characters)
# 3. Configure COOKIE_DOMAIN in backend/.env (e.g., .yourdomain.com)
# 4. Set NODE_ENV=production in backend/.env
# 5. Configure SSL certificates in docker/nginx/ssl/
# 6. Use production mode: docker-compose -f docker-compose.yml up -d
# 7. Configure firewall rules (only allow 80/443)
# 8. Set up backup strategy for PostgreSQL volumes
