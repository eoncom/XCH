# =============================================================================
# XCH Production Environment — v1.0.0-rc1
# Copy this file to .env.production and customize all CHANGE_ME values
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=xch_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=xch_dev

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MinIO (S3 Storage) ──────────────────────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_minio_access
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_min_16_chars

# ── JWT Secrets ──────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_random_64_char_string
JWT_REFRESH_SECRET=CHANGE_ME_different_random_64_char_string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
DEFAULT_TENANT_ID=tenant_default

# ── URLs (adjust to your domain) ────────────────────────────────────────────
# Leave empty when using built-in nginx (same-origin, no CORS needed)
# Set these when using external reverse proxy with separate domains
FRONTEND_URL=
FRONTEND_API_URL=
FRONTEND_APP_URL=

# ── Cookies ──────────────────────────────────────────────────────────────────
# Set to "true" for HTTPS, "false" for HTTP-only deployments
COOKIE_SECURE=true

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_TYPE=minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=xch-storage
# When behind nginx: leave empty (uses /storage/ relative path)
MINIO_PUBLIC_URL=

# ── Ports (host-side) ───────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
GATUS_PORT=8080

# ── Gatus Monitoring ────────────────────────────────────────────────────────
GATUS_WEBHOOK_SECRET=CHANGE_ME_webhook_secret

# ── NetBox Integration (optional) ───────────────────────────────────────────
# NETBOX_URL=https://netbox.example.com
# NETBOX_TOKEN=your_netbox_api_token

# ── Uptime Kuma Integration (optional) ──────────────────────────────────────
# UPTIME_KUMA_URL=http://uptime-kuma:3001
# UPTIME_KUMA_USERNAME=
# UPTIME_KUMA_PASSWORD=
