// XCH - Prisma Schema (v2.0 — Delegation-first model)
// PostgreSQL 15+ with PostGIS extension

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ============================================================================
// TENANT & AUTH
// ============================================================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  subdomain String       @unique
  status    TenantStatus @default(ACTIVE)

  // Branding
  logoUrl      String?
  primaryColor String? @default("#0070f3")

  // Configuration (JSON)
  config Json? @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users               User[]
  delegations         Delegation[]
  sites               Site[]
  assets              Asset[]
  racks               Rack[]
  tasks               Task[]
  contacts            Contact[]
  contactTypes        ContactType[]
  integrationMappings IntegrationMapping[]
  auditLogs           AuditLog[]
  enumLabels          EnumLabel[]
  billingEntities     BillingEntity[]
  expenses            Expense[]
  notificationConfigs NotificationConfig[]
  notificationLogs    NotificationLog[]
  userDelegations     UserDelegation[]
  accessOverrides     AccessOverride[]
  assetModels         AssetModel[]
  budgets             Budget[]
  connectivityLinks   ConnectivityLink[]
  userNotifications   UserNotification[]
  vendorCatalogs      VendorCatalog[]

  @@index([status])
  @@map("tenants")
}

// ============================================================================
// AUTHORIZATION ENUMS (v3.0 — MANAGE/WRITE/READ model)
// ============================================================================

enum DelegationRight {
  MANAGE // Gere la delegation : users, affectations, notifications, CRUD sites, + tout WRITE
  WRITE // Utilise l'application : CRUD assets, tasks, racks, plans, contacts, depenses
  READ // Consultation uniquement
}

enum OverrideEffect {
  ALLOW
  DENY
}

enum PermissionLevel {
  READ
  WRITE
}

model User {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identity
  email        String
  passwordHash String? // NULL if external auth only

  // Profile
  name      String
  phone     String?
  avatarUrl String?

  // Permissions
  isSuperAdmin Boolean @default(false) // Platform-level global access
  active       Boolean @default(true)

  // External auth
  externalId   String? // OIDC 'sub' or SAML nameID
  authProvider String  @default("local") // local, oidc, saml

  // TOTP 2FA
  totpSecret      String?
  totpEnabled     Boolean  @default(false)
  totpBackupCodes String[]

  // Invite & password reset tokens
  inviteToken       String?   @unique
  inviteTokenExpiry DateTime?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  // Account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Metadata
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Appearance (v1.4 — ADR-010)
  // When appearanceSource = 'inherit' (default) → user follows Tenant.config.appearance.
  // When appearanceSource = 'custom' → appearancePreference overrides tenant defaults
  // field by field, ONLY if Tenant.config.appearance.allowUserOverride === true.
  // Backend resolution happens in UsersService.getEffectiveAppearance().
  appearancePreference Json?   @db.JsonB // { theme?, primaryColor?, density? }
  appearanceSource     String  @default("inherit") // "inherit" | "custom"

  // Relations
  assignedTasks   Task[]           @relation("AssignedTo")
  createdTasks    Task[]           @relation("CreatedBy")
  taskComments    TaskComment[]    @relation("TaskComments")
  auditLogs       AuditLog[]
  photos          Photo[]
  accessOverrides AccessOverride[]
  assetMovements  AssetMovement[]
  userDelegations UserDelegation[]
  userNotifications UserNotification[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, externalId])
  @@map("users")
}

// ============================================================================
// ORGANISATION (Delegation → Site) — Delegation-first model
// ============================================================================
// Note: SSO configuration lives in Tenant.config.sso (JSON). The AuthProvider
// model + AuthProviderType enum were removed in v1.4.x (never exposed by any
// controller, fully covered by the JSON config path).

model Delegation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String  @db.VarChar(100)
  code     String  @db.VarChar(20)
  notes    String? @db.Text
  isActive Boolean @default(true)

  // Visual grouping tag (R8 — UI only, zero functional impact)
  groupLabel String? @db.VarChar(100)
  groupColor String? @db.VarChar(7) // Hex color

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sites               Site[]
  assets              Asset[]
  userDelegations     UserDelegation[]
  contacts            Contact[]
  billingEntities     BillingEntity[]
  expenses            Expense[]
  notificationConfigs NotificationConfig[]
  budgets             Budget[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("delegations")
}

// ============================================================================
// USER DELEGATIONS (right = source de verite permissions par delegation)
// ============================================================================

model UserDelegation {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  delegationId String
  delegation   Delegation      @relation(fields: [delegationId], references: [id], onDelete: Cascade)
  right        DelegationRight // MANAGE | WRITE | READ
  grantedBy    String?
  grantedAt    DateTime        @default(now())

  @@unique([userId, delegationId])
  @@index([tenantId, userId])
  @@index([delegationId])
  @@map("user_delegations")
}

// ============================================================================
// SITES (CHANTIERS)
// ============================================================================

enum SiteStatus {
  PREPARATION
  ACTIVE
  CLOSED
}

enum HealthStatus {
  HEALTHY
  WARNING
  CRITICAL
  UNKNOWN
}

model Site {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  delegationId String
  delegation   Delegation @relation(fields: [delegationId], references: [id], onDelete: Restrict)

  code   String
  name   String
  status SiteStatus @default(ACTIVE)

  // Location — address/city nullable pour les chantiers mobiles / temporaires
  // qui n'ont pas d'adresse postale (juste des coordonnées GPS). L'UI impose
  // qu'au moins un des deux soit fourni (address OU latitude+longitude).
  address    String?
  city       String?
  postalCode String?
  country    String  @default("France")

  // PostGIS geometry - POINT(longitude, latitude)
  coordinates Unsupported("geometry(Point,4326)")?

  // Contacts (JSON array)
  contacts Json? @db.JsonB // [{name, phone, email, role, isPrimary}]

  // Access notes (JSON)
  accessNotes Json? @db.JsonB // {schedules, badges, procedures, safety}

  // Connectivity (JSON)
  connectivity Json? @db.JsonB // {primary: {type, provider, ref}, backup, cutProcedure}

  // Document Emplacements (JSON array)
  emplacements Json? @db.JsonB // [{type: 'smb'|'sharepoint', url, description}]

  // Governance Documents Reference
  governanceDocsRef String? // URL to "Referentiel droits documents"

  // Monitoring
  monitoringEnabled Boolean @default(true)

  // Consumption (Lot E)
  autoGenerateElectricityExpense Boolean @default(false)

  // Health
  healthStatus    HealthStatus @default(UNKNOWN)
  lastHealthCheck DateTime?

  // Metadata
  metadata  Json?    @db.JsonB // {serverInfo: {smbPath, sharepointUrl, gedUrl, accessRightsUrl, notes}}
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assets          Asset[]
  racks           Rack[]
  floorPlans      FloorPlan[]
  tasks           Task[]
  externalRefs    ExternalRef[]
  photos          Photo[]
  billingEntities BillingEntity[]
  expenses        Expense[]
  contactsOnSite  Contact[]
  accessOverrides AccessOverride[]
  movementsFrom   AssetMovement[]  @relation("movementFromSite")
  movementsTo     AssetMovement[]  @relation("movementToSite")
  budgets         Budget[]
  connectivityLinks ConnectivityLink[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, healthStatus])
  @@index([delegationId])
  @@map("sites")
}

// ============================================================================
// ASSETS (EQUIPEMENTS)
// ============================================================================

// AssetType and AssetStatus enums removed in v1.3 — now dynamic Strings via EnumLabel

/// VendorCatalog — an imported "pack" of AssetModel templates.
/// v1.4.x — operators can upload JSON catalogs from the UI, list them, download
/// them back (for backup / sharing) and delete them. Each imported AssetModel is
/// linked to its origin catalog via AssetModel.vendorCatalogId so deleting a
/// catalog can optionally cascade to its models. The raw JSON is kept in
/// `content` (JSONB) so the exact uploaded payload is recoverable.
model VendorCatalog {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vendor      String   @db.VarChar(100)
  version     String?  @db.VarChar(50)
  sources     String[] @default([])
  /// Raw uploaded payload — preserved for re-download / audit / debugging.
  content     Json     @db.JsonB
  itemCount   Int      @default(0)

  /// true when the pack is a built-in bundled seed shipped with the app.
  builtIn     Boolean  @default(false)

  importedAt  DateTime @default(now())
  importedBy  String?

  assetModels AssetModel[]

  @@index([tenantId])
  @@index([tenantId, vendor])
  @@map("vendor_catalogs")
}

model AssetModel {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String            // e.g. "HP LaserJet Pro M404n"
  manufacturer     String?
  type             String            // AssetType (dynamic String)

  // Origin pack — null for manually-created models
  vendorCatalogId  String?
  vendorCatalog    VendorCatalog? @relation(fields: [vendorCatalogId], references: [id], onDelete: SetNull)

  // Pricing
  acquisitionPrice Decimal? @db.Decimal(10, 2) // one-time purchase price
  monthlyPrice     Decimal? @db.Decimal(10, 2) // monthly rental/lease price
  currency         String   @default("EUR")
  pricingMode      String   @default("ONE_TIME") // ONE_TIME | MONTHLY

  // Template specs
  powerConsumption Float?   // Watts
  weight           Float?   // kg
  defaultUHeight   Int?     // default rack height

  // WiFi AP template defaults (v1.4.x) — pre-filled on assets created from the model.
  // Only meaningful for AssetModel.type === 'WIFI_AP', but kept optional to avoid
  // schema branching. Ignored by the frontend for non-WiFi types.
  wifiCoverageRadius Float?   // meters — default coverage radius drawn on floor plans
  wifiFrequency      String?  // "2.4GHz" | "5GHz" | "6GHz" | "DUAL" | "TRI"
  wifiAntennaType    String?  // "OMNI" | "DIRECTIONAL" | "SECTOR"
  wifiTxPowerDbm     Int?     // transmit power in dBm

  notes            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assets Asset[]

  @@unique([tenantId, name])
  @@index([tenantId, type, isActive])
  @@map("asset_models")
}

model Asset {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  delegationId String?
  delegation   Delegation? @relation(fields: [delegationId], references: [id])
  siteId       String?
  site         Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  type         String      // was AssetType enum — dynamic via EnumLabel
  name         String?
  model        String?
  manufacturer String?
  serialNumber String?
  inventoryTag String?
  status       String      @default("IN_SERVICE") // was AssetStatus enum — dynamic via EnumLabel

  // Model & pricing
  assetModelId     String?
  assetModel       AssetModel? @relation(fields: [assetModelId], references: [id])
  acquisitionPrice Decimal?    @db.Decimal(10, 2) // purchase price
  monthlyPrice     Decimal?    @db.Decimal(10, 2) // monthly rental/lease
  priceCurrency    String      @default("EUR")

  // Location
  locationText String?

  // Network info (JSON)
  networkInfo Json? @db.JsonB // {ip, mac, hostname, vlan, port}

  // Rack mounting (optional)
  rackId        String?
  rack          Rack?   @relation(fields: [rackId], references: [id], onDelete: SetNull)
  rackPositionU Int? // Starting U position
  rackHeightU   Int? // Height in U
  rackNotes     String? // Notes for this asset when mounted in rack

  // QR Code
  qrCodeUrl   String? @db.Text // Base64 data URL of QR code image
  qrCodeToken String? // Secure token for QR validation

  // Metadata
  purchaseDate     DateTime?
  warrantyEnd      DateTime?
  weight           Float? // kg
  powerConsumption Float? // Watts
  dutyCyclePercent Int     @default(100) // Effective usage % (0-100) for consumption estimation
  notes            String?   @db.Text

  // WiFi AP coverage (for floor-plan rendering)
  wifiCoverageRadius Float?  // meters — used to draw coverage circle on floor plans
  wifiFrequency      String? // "2.4GHz" | "5GHz" | "6GHz" | "DUAL" | "TRI"
  wifiAntennaType    String? // "OMNI" | "DIRECTIONAL" | "SECTOR"
  wifiTxPowerDbm     Int?    // transmit power in dBm

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  pins         Pin[]
  tasks        Task[]
  externalRefs ExternalRef[]
  photos       Photo[]
  movements    AssetMovement[]

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([tenantId, delegationId])
  @@index([tenantId, siteId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([rackId])
  @@map("assets")
}

// ============================================================================
// ASSET MOVEMENT HISTORY
// ============================================================================

enum AssetMovementType {
  SITE_CHANGE // Changed site
  RACK_MOUNT // Mounted in rack
  RACK_UNMOUNT // Unmounted from rack
  RACK_MOVE // Moved within rack (position change)
  RACK_CHANGE // Moved to different rack
  STATUS_CHANGE // Status changed
  CREATED // Asset created
}

model AssetMovement {
  id       String            @id @default(cuid())
  tenantId String
  assetId  String
  asset    Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId   String?
  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  type     AssetMovementType

  // Site change tracking
  fromSiteId String?
  fromSite   Site?   @relation("movementFromSite", fields: [fromSiteId], references: [id], onDelete: SetNull)
  toSiteId   String?
  toSite     Site?   @relation("movementToSite", fields: [toSiteId], references: [id], onDelete: SetNull)

  // Rack change tracking
  fromRackId        String?
  fromRack          Rack?   @relation("movementFromRack", fields: [fromRackId], references: [id], onDelete: SetNull)
  toRackId          String?
  toRack            Rack?   @relation("movementToRack", fields: [toRackId], references: [id], onDelete: SetNull)
  fromRackPositionU Int?
  toRackPositionU   Int?

  // Status change tracking
  fromStatus String?
  toStatus   String?

  // Metadata
  notes     String?  @db.Text
  timestamp DateTime @default(now())

  @@index([tenantId, assetId])
  @@index([assetId, timestamp])
  @@map("asset_movements")
}

// ============================================================================
// RACKS (BAIES)
// ============================================================================

enum RackType {
  WALL_MOUNTED
  FLOOR_STANDING
  ENCLOSED_CABINET
}

enum RackStatus {
  IN_SERVICE
  OUT_OF_SERVICE
  PREPARATION
}

model Rack {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId       String
  site         Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name         String
  serialNumber String?
  model        String?
  manufacturer String?
  heightU      Int // 4, 6, 12, 18, 24, 42
  rackType     RackType   @default(FLOOR_STANDING)
  status       RackStatus @default(IN_SERVICE)
  location     String?

  // Specs (JSON)
  specs Json? @db.JsonB // {dimensions, depth, maxLoad, cooling, security, power}

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assets        Asset[]
  pins          Pin[]
  movementsFrom AssetMovement[] @relation("movementFromRack")
  movementsTo   AssetMovement[] @relation("movementToRack")

  @@unique([tenantId, siteId, name])
  @@index([tenantId])
  @@index([tenantId, siteId])
  @@map("racks")
}

// ============================================================================
// FLOOR PLANS & PINS
// ============================================================================

model FloorPlan {
  id          String  @id @default(cuid())
  siteId      String
  site        Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title       String
  version     Int     @default(1)
  planGroupId String? // Groups versions of the same plan together

  // File
  fileUrl  String
  fileSize Int?
  mimeType String?

  // Metadata
  notes      String?  @db.Text
  uploadedBy String
  uploadedAt DateTime @default(now())

  // Scale calibration (for heatmap / measurements)
  scaleMetersPerPixel Float? // Meters per normalized unit (0-1)
  scaleRefLine        Json?  @db.JsonB // {x1,y1,x2,y2,meters} reference line

  // Relations
  pins Pin[]

  @@index([siteId])
  @@index([siteId, version])
  @@index([planGroupId])
  @@map("floor_plans")
}

// PinType enum removed in v1.3 — now dynamic String via EnumLabel

model Pin {
  id          String    @id @default(cuid())
  floorPlanId String
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)

  // Normalized coordinates (0.0 to 1.0)
  x Float
  y Float

  // Type & association
  pinType String // was PinType enum — dynamic via EnumLabel
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  rackId  String?
  rack    Rack?   @relation(fields: [rackId], references: [id], onDelete: Cascade)

  label       String?
  description String? @db.Text
  icon        String?
  color       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([floorPlanId])
  @@index([assetId])
  @@index([rackId])
  @@map("pins")
}

// ============================================================================
// TASKS
// ============================================================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId      String
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assetId     String?
  asset       Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)

  // Assignment
  assignedTo   String?
  assignedUser User?   @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  createdBy    String?
  creator      User?   @relation("CreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  // Scheduling
  dueDate DateTime?

  // TicketLink
  ticketRef    String?
  ticketUrl    String?
  ticketStatus String?

  // Costs (prestations)
  estimatedCost Decimal? @db.Decimal(10, 2)
  actualCost    Decimal? @db.Decimal(10, 2)
  costCurrency  String   @default("EUR")

  // Linked expense (ADR-011) — 1:1, populated when the user opts in to
  // generate an Expense from this task on completion. Symmetric with
  // ConnectivityLink.expenseId.
  expenseId String?
  expense   Expense? @relation("taskExpense", fields: [expenseId], references: [id], onDelete: SetNull)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  photos         Photo[]
  checklistItems TaskChecklistItem[]
  comments       TaskComment[]

  @@index([tenantId])
  @@index([tenantId, siteId])
  @@index([tenantId, status])
  @@index([tenantId, assignedTo])
  @@index([tenantId, dueDate])
  @@index([expenseId])
  @@map("tasks")
}

model TaskChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  checked   Boolean  @default(false)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([taskId, order])
  @@map("task_checklist_items")
}

model TaskComment {
  id       String  @id @default(cuid())
  taskId   String
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId String
  author   User    @relation("TaskComments", fields: [authorId], references: [id])
  text     String  @db.Text
  // isSystem: true = auto-generated comment (status change, blocking reason, etc.)
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([taskId, createdAt])
  @@map("task_comments")
}

// ============================================================================
// CONTACTS & CONTACT TYPES
// ============================================================================

enum ContactCategory {
  PROVIDER // Fournisseurs externes (telecom, cloud, energie...)
  INTERNAL // Equipes internes (responsable site, gardien...)
  PARTNER // Partenaires IT externes (integrateurs, sous-traitants)
  TECHNICAL // Support technique (NetBox, monitoring)
  EMERGENCY // Contacts urgence
}

model ContactType {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String          @db.VarChar(50) // "Telecommunications", "Plomberie"
  slug     String          @db.VarChar(50) // "telecom", "plomberie"
  category ContactCategory // Categorisation fonctionnelle
  color    String?         @db.VarChar(7) // Hex color "#3b82f6"
  icon     String?         @db.VarChar(50) // Lucide icon name

  isSystem Boolean @default(false) // true = predefini, non supprimable
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contacts Contact[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("contact_types")
}

model Contact {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String @db.VarChar(100)

  // FK vers ContactType
  typeId String
  type   ContactType @relation(fields: [typeId], references: [id])

  // Coordonnees enrichies
  email   String? @db.VarChar(100)
  phone   String? @db.VarChar(50)
  mobile  String? @db.VarChar(50)
  address String? @db.Text

  // Contexte professionnel
  company String? @db.VarChar(100) // Entreprise
  role    String? @db.VarChar(100) // Fonction/role

  notes String? @db.Text

  // Rattachement organisationnel (R3)
  // delegationId=null → global (super admin only, visible en lecture partout)
  delegationId String?
  delegation   Delegation? @relation(fields: [delegationId], references: [id])
  // siteId optionnel — validation R1 : site.delegationId must match delegationId
  siteId       String?
  site         Site?       @relation(fields: [siteId], references: [id])

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  externalRefs     ExternalRef[]
  expensesAsVendor Expense[]     @relation("expenseVendor")

  @@index([tenantId])
  @@index([tenantId, typeId])
  @@index([tenantId, delegationId])
  @@map("contacts")
}

// ============================================================================
// INTEGRATION MAPPINGS
// ============================================================================

model IntegrationMapping {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Source externe
  provider      String // "netbox", "uptime_kuma", "checkmk"
  entityType    String // "contact_group", "site_status", "device_role"
  externalId    String // ID ou slug dans le systeme externe
  externalLabel String // Nom affiche (cache)

  // Cible XCH
  targetType String // "contact_type", "site_status", "asset_type"
  targetId   String // ID de l'entite XCH cible

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, provider, entityType, externalId])
  @@index([tenantId, provider, entityType])
  @@map("integration_mappings")
}

// ============================================================================
// PHOTOS & ATTACHMENTS
// ============================================================================

enum EntityType {
  SITE
  ASSET
  TASK
  RACK
  CONTACT
}

model Photo {
  id         String     @id @default(cuid())
  entityType EntityType
  entityId   String

  // Polymorphic relations
  site  Site?  @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_siteId_fkey")
  asset Asset? @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_assetId_fkey")
  task  Task?  @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_taskId_fkey")

  // File
  fileUrl  String
  fileName String
  fileSize Int?
  mimeType String

  // Metadata
  caption    String?
  uploadedBy String
  uploader   User     @relation(fields: [uploadedBy], references: [id])
  uploadedAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([uploadedAt])
  @@map("photos")
}

// ============================================================================
// EXTERNAL REFS (INTEGRATIONS)
// ============================================================================

model ExternalRef {
  id         String     @id @default(cuid())
  entityType EntityType
  entityId   String

  // Polymorphic relations
  site    Site?    @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "external_refs_siteId_fkey")
  asset   Asset?   @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "external_refs_assetId_fkey")
  contact Contact? @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "external_refs_contactId_fkey")

  // Integration provider
  provider    String // netbox, uptime_kuma, fortimanager
  externalId  String
  externalUrl String?

  // Metadata (JSON)
  metadata  Json?     @db.JsonB
  lastSync  DateTime?
  createdAt DateTime  @default(now())

  @@unique([entityType, entityId, provider])
  @@index([entityType, entityId])
  @@index([provider])
  @@map("external_refs")
}

// ============================================================================
// ATTACHMENTS
// ============================================================================

model Attachment {
  id       String @id @default(cuid())
  tenantId String

  // Polymorphic relation (assetId, taskId, rackId, or siteId)
  assetId String?
  taskId  String?
  rackId  String?
  siteId  String?

  // File metadata
  filename         String
  originalFilename String
  size             Int
  mimetype         String
  path             String // MinIO path: attachments/{tenantId}/{entityType}/{entityId}/{timestamp}_{filename}

  // Optional metadata
  description String?
  category    String? // spec, invoice, photo, report, manual, other

  // Audit
  uploadedBy String
  uploadedAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, assetId])
  @@index([tenantId, taskId])
  @@index([tenantId, rackId])
  @@index([tenantId, siteId])
  @@map("attachments")
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // CREATE, UPDATE, DELETE
  entityType String
  entityId   String?

  // Changes (JSON)
  changes Json? @db.JsonB // {before: {...}, after: {...}}

  // Context
  ipAddress String?
  userAgent String?

  timestamp DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, timestamp])
  @@index([tenantId, userId])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

// ============================================================================
// ACCESS OVERRIDES (exceptions ALLOW/DENY par site ou ressource)
// ============================================================================

model AccessOverride {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId   String
  site     Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // "*" = site complet, ou "assets","racks","tasks","plans","contacts","expenses","monitoring"
  resource   String           @default("*")
  effect     OverrideEffect
  permission PermissionLevel? // obligatoire si ALLOW, null si DENY

  label     String?   @db.VarChar(100)
  grantedBy String?
  grantedAt DateTime  @default(now())
  expiresAt DateTime?

  @@unique([tenantId, userId, siteId, resource])
  @@index([tenantId, userId])
  @@index([tenantId, siteId])
  @@map("access_overrides")
}

// ============================================================================
// ENUM LABELS (Custom labels for enums per tenant)
// ============================================================================

model EnumLabel {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enumType  String // "AssetType", "PinType", "AssetStatus"
  enumValue String // "SWITCH", "FIREWALL", etc.
  label     String // Custom display label
  icon      String? // Custom icon name
  color     String? // Custom color hex
  sortOrder Int     @default(0)
  isHidden  Boolean @default(false)
  isBuiltIn Boolean @default(false) // true = valeur système non-supprimable
  isActive  Boolean @default(true)  // false = désactivée (pas proposée dans les selects)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, enumType, enumValue])
  @@index([tenantId])
  @@index([tenantId, enumType])
  @@index([tenantId, enumType, isActive])
  @@map("enum_labels")
}

// ============================================================================
// COST ALLOCATION
// ============================================================================

enum ExpenseType {
  EQUIPMENT
  SERVICE
  PROJECT
  CONSUMABLE
  LICENSE
  OTHER
}

enum ExpenseFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

model BillingEntity {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String  @db.VarChar(100)
  code        String  @db.VarChar(20)
  type        String  @db.VarChar(50) // "DIRECTION", "BU", "DELEGATION", "SITE", "SERVICE", "OTHER"
  description String? @db.Text
  isActive    Boolean @default(true)

  // Rattachement organisationnel (R1, R2)
  // delegationId=null → global (super admin, visible partout en lecture)
  delegationId String?
  delegation   Delegation? @relation(fields: [delegationId], references: [id])
  // siteId optionnel — validation R1 : site.delegationId must match delegationId
  siteId       String?
  site         Site?       @relation(fields: [siteId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  expensesBorne       Expense[]        @relation("bearer")
  allocationsReceived CostAllocation[] @relation("target")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, delegationId])
  @@map("billing_entities")
}

model Expense {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // What
  label       String      @db.VarChar(200)
  description String?     @db.Text
  type        ExpenseType @default(OTHER)

  // How much
  totalAmount Float
  currency    String           @default("EUR") @db.VarChar(3)
  frequency   ExpenseFrequency @default(ONE_TIME)

  // When
  dateIncurred DateTime
  dateStart    DateTime?
  dateEnd      DateTime?

  // Who pays (bearer)
  bearerId String
  bearer   BillingEntity @relation("bearer", fields: [bearerId], references: [id])

  // Rattachement organisationnel (R1, R2 — delegationId OBLIGATOIRE)
  delegationId String
  delegation   Delegation @relation(fields: [delegationId], references: [id])
  // siteId optionnel — validation R1
  siteId       String?
  site         Site?      @relation(fields: [siteId], references: [id])

  // Optional links to XCH entities
  assetId     String?
  externalRef String? @db.VarChar(200)

  // Vendor — FK vers Contact (source de verite fournisseurs)
  vendorId      String?
  vendorContact Contact? @relation("expenseVendor", fields: [vendorId], references: [id], onDelete: SetNull)

  // References
  invoiceRef String? @db.VarChar(100)
  poNumber   String? @db.VarChar(50)

  notes     String?  @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Allocations
  allocations CostAllocation[]

  // Linked connectivity (optional reverse for ConnectivityLink.expenseId)
  connectivityLinks ConnectivityLink[]

  // Linked tasks (ADR-011) — reverse for Task.expenseId. Modeled as N:1 by
  // Prisma (mirrors ConnectivityLink) but enforced 1:1 at the service layer
  // (createFromTask refuses if task already has an expense linked).
  tasks Task[] @relation("taskExpense")

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([bearerId])
  @@index([tenantId, delegationId])
  @@index([vendorId])
  @@map("expenses")
}

model CostAllocation {
  id        String  @id @default(cuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  // Target
  targetId String
  target   BillingEntity @relation("target", fields: [targetId], references: [id])

  // Allocation
  percentage Float
  amount     Float

  notes String? @db.Text

  @@index([expenseId])
  @@index([targetId])
  @@map("cost_allocations")
}

// ============================================================================
// BUDGETS
// ============================================================================

enum BudgetPeriod {
  MONTH
  YEAR
}

model Budget {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label        String
  delegationId String?
  delegation   Delegation?  @relation(fields: [delegationId], references: [id])
  siteId       String?
  site         Site?        @relation(fields: [siteId], references: [id])
  expenseType  String?      // "EQUIPMENT" | "SERVICE" | ... (matches ExpenseType)
  period       BudgetPeriod @default(YEAR)
  startDate    DateTime
  endDate      DateTime
  amount       Decimal      @db.Decimal(12, 2)
  currency     String       @default("EUR")
  notes        String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId, startDate, endDate])
  @@index([tenantId, delegationId])
  @@map("budgets")
}

// ============================================================================
// CONNECTIVITY LINKS (structured replacement of Site.connectivity JSON)
// ============================================================================

enum ConnectivityRole {
  PRIMARY
  BACKUP
  OTHER
}

model ConnectivityLink {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId         String
  site           Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)

  role           ConnectivityRole  @default(PRIMARY)
  provider       String            // ISP name ("Orange", "SFR", "Starlink")
  type           String            // "FIBER" | "ADSL" | "4G" | "5G" | "STARLINK" | ...
  bandwidthDown  Int?              // Mbps
  bandwidthUp    Int?              // Mbps
  publicIp       String?
  monthlyPrice   Decimal?          @db.Decimal(10, 2)
  currency       String            @default("EUR")
  startDate      DateTime?
  endDate        DateTime?
  contractRef    String?
  notes          String?           @db.Text

  // Linked recurring expense (optional)
  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, siteId])
  @@index([tenantId, role])
  @@map("connectivity_links")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

/// Configuration des notifications par delegation (R4)
/// Heritage : global (delegationId=null) → delegation
model NotificationConfig {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Rattachement : null = global tenant config, sinon = delegation-specific
  delegationId String?
  delegation   Delegation? @relation(fields: [delegationId], references: [id], onDelete: Cascade)

  /// Config canaux : { email: { inherit, enabled, recipients[] }, teams: { inherit, enabled, webhookUrl } }
  channels Json @db.JsonB

  /// Config evenements : { TASK_ASSIGNED: { inherit, enabled, channels[] }, ... }
  events Json @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, delegationId])
  @@index([tenantId])
  @@map("notification_configs")
}

/// Journal des notifications envoyees (audit) (R12)
model NotificationLog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Type d'evenement (TASK_ASSIGNED, SITE_STATUS_CHANGED, etc.)
  eventType    String  @db.VarChar(50)
  /// Canal utilise (email, teams)
  channel      String  @db.VarChar(20)
  /// Delegation qui a declenche
  delegationId String?

  /// Destinataire (email ou webhook URL)
  recipient    String
  /// Sujet/titre
  subject      String
  /// Succes ou echec
  success      Boolean @default(true)
  /// Message d'erreur si echec
  errorMessage String? @db.Text

  /// Contexte de l'evenement (JSON: entityId, entityType, siteId, details...)
  context Json? @db.JsonB

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, eventType])
  @@map("notification_logs")
}

/// In-app notification inbox per user (R12b)
model UserNotification {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  String  @db.VarChar(60) // TASK_ASSIGNED | WARRANTY_EXPIRING | TASK_DUE_SOON | ...
  title String
  body  String? @db.Text
  link  String? // relative URL inside the app

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([tenantId, createdAt])
  @@map("user_notifications")
}
