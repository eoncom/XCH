// XCH - Prisma Schema (v2.0 — Delegation-first model)
// PostgreSQL 15+ with PostGIS extension

generator client {
  provider = "prisma-client-js"
  // ADR-020 §C — `@@unique(..., nulls: "not distinct")` is GA since
  // Prisma 5.7. The previously-considered "nullsNotDistinct" preview
  // flag does NOT exist in 5.22 (validation rejects it). The option on
  // @@unique works on its own ; see notification_channels / rules below.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ============================================================================
// TENANT & AUTH
// ============================================================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  subdomain String       @unique
  status    TenantStatus @default(ACTIVE)

  // Tenant.config JSON dropped in S6 (ADR-018) — split into typed relations
  // below: featureFlags / electricity / appearance / branding / ssoConfig /
  // securityReminders. logoUrl/primaryColor remain as legacy short-hand on
  // Tenant (also mirrored in TenantBranding).
  logoUrl      String?
  primaryColor String? @default("#0070f3")

  // SSRF policy (ADR-016, was ADR-014.allowInternalMonitorTargets) — when true,
  // any operator-supplied URL/host (monitor probes, Teams webhook, future
  // integrations) targeting RFC1918 private ranges (10/8, 172.16/12,
  // 192.168/16) and IPv6 unique-local is accepted at CRUD AND probe-time.
  // Loopback (127/8, ::1), link-local (169.254/16), multicast and 0/8 remain
  // blocked regardless. Default false for safety on multi-tenant cloud
  // deployments; pre-enabled by the seed for the on-prem pilot tenant
  // (chantiers = LAN partout).
  allowInternalNetworkTargets Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users               User[]
  delegations         Delegation[]
  sites               Site[]
  assets              Asset[]
  racks               Rack[]
  tasks               Task[]
  contacts            Contact[]
  contactTypes        ContactType[]
  integrationMappings IntegrationMapping[]
  auditLogs           AuditLog[]
  enumLabels          EnumLabel[]
  billingEntities     BillingEntity[]
  expenses            Expense[]
  notificationChannels NotificationChannel[]
  notificationRules    NotificationRule[]
  notificationLogs    NotificationLog[]
  userDelegations     UserDelegation[]
  accessOverrides     AccessOverride[]
  assetModels         AssetModel[]
  budgets             Budget[]
  connectivityLinks   ConnectivityLink[]
  sdwanConfigs        SdwanConfig[]
  userNotifications   UserNotification[]
  vendorCatalogs      VendorCatalog[]
  monitorChecks       MonitorCheck[]

  // Typed config relations (ADR-018, ex-Tenant.config)
  featureFlags       TenantFeatureFlag[]
  electricity        TenantElectricityConfig?
  appearance         TenantAppearance?
  branding           TenantBranding?
  ssoConfig          TenantSsoConfig?
  securityConfig     TenantSecurityConfig?
  integrationConfig  TenantIntegrationConfig?
  securityReminders  TenantSecurityReminder[]

  @@index([status])
  @@map("tenants")
}

// ----- Tenant config split (ADR-018) ---------------------------------------

// 1 row per tenant × module name. Replaces Tenant.config.modules JSON map.
model TenantFeatureFlag {
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String   // 'floor_plans', 'integrations_netbox', 'tasks', …
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@id([tenantId, name])
  @@map("tenant_feature_flags")
}

model TenantElectricityConfig {
  tenantId   String   @id
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  costPerKwh Decimal  @default(0.20) @db.Decimal(10, 4)
  currency   String   @default("EUR")
  updatedAt  DateTime @updatedAt

  @@map("tenant_electricity_configs")
}

model TenantAppearance {
  tenantId          String   @id
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  theme             String   @default("light")        // 'light' | 'dark' | 'auto'
  primaryColor      String   @default("#0070f3")
  density           String   @default("comfortable")  // 'comfortable' | 'compact'
  allowUserOverride Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  @@map("tenant_appearance_configs")
}

model TenantBranding {
  tenantId         String   @id
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl          String?
  primaryColor     String?
  secondaryColor   String?
  accentColor      String?
  organizationName String?
  // Color theme preset id (e.g. 'blue', 'green', …) consumed by
  // BrandingProvider on the frontend. NULL ⇒ fall back to primaryColor.
  // Distinct from TenantAppearance.theme which is the light/dark/auto mode.
  theme            String?
  updatedAt        DateTime @updatedAt

  @@map("tenant_branding_configs")
}

model TenantSsoConfig {
  tenantId     String   @id
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider     String   // 'oidc' | 'azure-ad' | …
  clientId     String
  clientSecret String   // TODO encrypted-at-rest in a future ADR
  issuerUrl    String?
  callbackUrl  String?
  scopes       String?  // space-separated
  groupClaim   String?  // claim name in JWT mapping to delegations
  // SSO group → DelegationRight mapping. Free-form list of {sourceLabel, right}
  // shaped exactly like the legacy roleMapping JSON. Kept as a JSONB column
  // because the keys are tenant-defined Entra/AD group names (no enum, no
  // metric, no query). See Décision E in ADR-018.
  roleMapping  Json?    @db.JsonB
  enabled      Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  @@map("tenant_sso_configs")
}

model TenantSecurityConfig {
  tenantId             String   @id
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  require2FA           Boolean  @default(false)
  sessionTimeout       String   @default("15m")
  refreshTokenLifetime String   @default("7d")
  updatedAt            DateTime @updatedAt

  @@map("tenant_security_configs")
}

// External integrations credentials (NetBox today; Gatus/Kuma removed in
// ADR-016). Single 1:0..1 with the providers we actually support.
model TenantIntegrationConfig {
  tenantId     String   @id
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  netboxUrl    String?
  netboxToken  String?  // TODO encrypted-at-rest with TenantSsoConfig.clientSecret
  updatedAt    DateTime @updatedAt

  @@map("tenant_integration_configs")
}

enum SecurityReminderSeverity {
  INFO
  WARNING
  CRITICAL
}

// Login-page security notices. ADR-018 promoted from
// Tenant.config.branding.securityReminders JSON-list to a typed table to
// support per-site scoping (BTP chantiers vs office sites) and severity.
model TenantSecurityReminder {
  id        String                   @id @default(cuid())
  tenantId  String
  tenant    Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Optional site scope. NULL = applies to all sites in the tenant.
  siteId    String?
  site      Site?                    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title     String
  body      String                   @db.Text
  severity  SecurityReminderSeverity @default(INFO)
  category  String?                  // 'EPI' | 'Accès' | 'Procédures' | …
  order     Int                      @default(0)
  enabled   Boolean                  @default(true)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@index([tenantId])
  @@index([tenantId, siteId])
  @@map("tenant_security_reminders")
}

// ============================================================================
// AUTHORIZATION ENUMS (v3.0 — MANAGE/WRITE/READ model)
// ============================================================================

enum DelegationRight {
  MANAGE // Gere la delegation : users, affectations, notifications, CRUD sites, + tout WRITE
  WRITE // Utilise l'application : CRUD assets, tasks, racks, plans, contacts, depenses
  READ // Consultation uniquement
}

enum OverrideEffect {
  ALLOW
  DENY
}

enum PermissionLevel {
  READ
  WRITE
}

model User {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identity
  email        String
  passwordHash String? // NULL if external auth only

  // Profile
  name      String
  phone     String?
  avatarUrl String?

  // Permissions
  isSuperAdmin Boolean @default(false) // Platform-level global access
  active       Boolean @default(true)

  // External auth
  externalId   String? // OIDC 'sub' or SAML nameID
  authProvider String  @default("local") // local, oidc, saml

  // TOTP 2FA
  totpSecret      String?
  totpEnabled     Boolean  @default(false)
  totpBackupCodes String[]

  // Invite & password reset tokens
  inviteToken       String?   @unique
  inviteTokenExpiry DateTime?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  // Account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Metadata
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Appearance (v1.4 — ADR-010, split scalars in S6 — ADR-018)
  // When appearanceSource = 'inherit' (default) → user follows TenantAppearance.
  // When appearanceSource = 'custom' → the 3 scalars below override the tenant
  // defaults field-by-field, but ONLY if TenantAppearance.allowUserOverride.
  // Backend resolution happens in UsersService.getEffectiveAppearance().
  appearanceTheme        String? // 'light' | 'dark' | 'auto'
  appearancePrimaryColor String?
  appearanceDensity      String? // 'comfortable' | 'compact'
  appearanceSource       String  @default("inherit") // "inherit" | "custom"

  // Relations
  assignedTasks        Task[]             @relation("AssignedTo")
  createdTasks         Task[]             @relation("CreatedBy")
  taskComments         TaskComment[]      @relation("TaskComments")
  auditLogs            AuditLog[]
  photos               Photo[]
  accessOverrides      AccessOverride[]
  assetMovements       AssetMovement[]
  userDelegations      UserDelegation[]
  userNotifications    UserNotification[]
  createdMonitorChecks MonitorCheck[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, externalId])
  @@map("users")
}

// ============================================================================
// ORGANISATION (Delegation → Site) — Delegation-first model
// ============================================================================
// Note: SSO configuration lives in Tenant.config.sso (JSON). The AuthProvider
// model + AuthProviderType enum were removed in v1.4.x (never exposed by any
// controller, fully covered by the JSON config path).

model Delegation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String  @db.VarChar(100)
  code     String  @db.VarChar(20)
  notes    String? @db.Text
  isActive Boolean @default(true)

  // Visual grouping tag (R8 — UI only, zero functional impact)
  groupLabel String? @db.VarChar(100)
  groupColor String? @db.VarChar(7) // Hex color

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sites               Site[]
  assets              Asset[]
  userDelegations     UserDelegation[]
  contacts            Contact[]
  billingEntities     BillingEntity[]
  expenses            Expense[]
  notificationChannels NotificationChannel[]
  notificationRules    NotificationRule[]
  budgets             Budget[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("delegations")
}

// ============================================================================
// USER DELEGATIONS (right = source de verite permissions par delegation)
// ============================================================================

model UserDelegation {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  delegationId String
  delegation   Delegation      @relation(fields: [delegationId], references: [id], onDelete: Cascade)
  right        DelegationRight // MANAGE | WRITE | READ
  grantedBy    String?
  grantedAt    DateTime        @default(now())

  @@unique([userId, delegationId])
  @@index([tenantId, userId])
  @@index([delegationId])
  @@map("user_delegations")
}

// ============================================================================
// SITES (CHANTIERS)
// ============================================================================

enum SiteStatus {
  PREPARATION
  ACTIVE
  CLOSED
}

enum HealthStatus {
  HEALTHY
  WARNING
  CRITICAL
  UNKNOWN
}

model Site {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  delegationId String
  delegation   Delegation @relation(fields: [delegationId], references: [id], onDelete: Restrict)

  code   String
  name   String
  status SiteStatus @default(ACTIVE)

  // Location — address/city nullable pour les chantiers mobiles / temporaires
  // qui n'ont pas d'adresse postale (juste des coordonnées GPS). L'UI impose
  // qu'au moins un des deux soit fourni (address OU latitude+longitude).
  address    String?
  city       String?
  postalCode String?
  country    String  @default("France")

  // PostGIS geometry - POINT(longitude, latitude)
  coordinates Unsupported("geometry(Point,4326)")?

  // ADR-018 — Site.contacts JSON dropped, all contacts live in the Contact
  // table via contactsOnSite (1:N) relation.

  // Access notes — split from former JSON {schedules, badges, procedures,
  // safety} into 4 free-form Text columns (ADR-018 cible D.2).
  accessSchedules  String? @db.Text
  accessBadges     String? @db.Text
  accessProcedures String? @db.Text
  accessSafety     String? @db.Text

  // Connectivity moved to the structured ConnectivityLink[] table in v1.3
  // (ADR-009 follow-up). Legacy JSON column dropped in phase 6.5 — the
  // structured model carries FKs to Expense (ADR-011) and is the single
  // source of truth. The `cutProcedure` field migrated to Site.cutProcedure
  // below, and per-link data lives in ConnectivityLink rows filtered by siteId.
  cutProcedure String? @db.Text

  // ADR-018 — Site.emplacements JSON dropped, list lives in SiteEmplacement
  // typed table (1:N) with EmplacementType enum.

  // Governance Documents Reference
  governanceDocsRef String? // URL to "Referentiel droits documents"

  // Server / document portal URLs — split from former Site.metadata.serverInfo
  // JSON (ADR-018 cible D.4). `notes` already existed as a column on Site.
  smbPath          String?
  sharepointUrl    String?
  gedUrl           String?
  accessRightsUrl  String?

  // Monitoring
  monitoringEnabled Boolean @default(true)

  // Consumption (Lot E)
  autoGenerateElectricityExpense Boolean @default(false)

  // Health
  healthStatus    HealthStatus @default(UNKNOWN)
  lastHealthCheck DateTime?

  // ADR-018 — Site.metadata JSON dropped (last consumer healthBreakdown
  // moved to SiteHealthSnapshot in cible C; serverInfo split above in cible D).
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assets            Asset[]
  racks             Rack[]
  floorPlans        FloorPlan[]
  tasks             Task[]
  externalRefs      ExternalRef[]
  photos            Photo[]
  billingEntities   BillingEntity[]
  expenses          Expense[]
  contactsOnSite    Contact[]
  emplacements      SiteEmplacement[]
  securityReminders TenantSecurityReminder[]
  healthSnapshot    SiteHealthSnapshot?
  accessOverrides   AccessOverride[]
  movementsFrom     AssetMovement[]    @relation("movementFromSite")
  movementsTo       AssetMovement[]    @relation("movementToSite")
  budgets           Budget[]
  connectivityLinks ConnectivityLink[]
  sdwanConfig       SdwanConfig?
  monitorChecks     MonitorCheck[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, healthStatus])
  @@index([delegationId])
  @@map("sites")
}

// ============================================================================
// ASSETS (EQUIPEMENTS)
// ============================================================================

// AssetType and AssetStatus enums removed in v1.3 — now dynamic Strings via EnumLabel

/// VendorCatalog — an imported "pack" of AssetModel templates.
/// v1.4.x — operators can upload JSON catalogs from the UI, list them, download
/// them back (for backup / sharing) and delete them. Each imported AssetModel is
/// linked to its origin catalog via AssetModel.vendorCatalogId so deleting a
/// catalog can optionally cascade to its models. The raw JSON is kept in
/// `content` (JSONB) so the exact uploaded payload is recoverable.
model VendorCatalog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vendor    String   @db.VarChar(100)
  version   String?  @db.VarChar(50)
  sources   String[] @default([])
  /// Raw uploaded payload — preserved for re-download / audit / debugging.
  content   Json     @db.JsonB
  itemCount Int      @default(0)

  /// true when the pack is a built-in bundled seed shipped with the app.
  builtIn Boolean @default(false)

  importedAt DateTime @default(now())
  importedBy String?

  assetModels AssetModel[]

  @@index([tenantId])
  @@index([tenantId, vendor])
  @@map("vendor_catalogs")
}

model AssetModel {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String // e.g. "HP LaserJet Pro M404n"
  manufacturer String?
  type         String // AssetType (dynamic String)

  // Origin pack — null for manually-created models
  vendorCatalogId String?
  vendorCatalog   VendorCatalog? @relation(fields: [vendorCatalogId], references: [id], onDelete: SetNull)

  // Pricing
  acquisitionPrice Decimal? @db.Decimal(10, 2) // one-time purchase price
  monthlyPrice     Decimal? @db.Decimal(10, 2) // monthly rental/lease price
  currency         String   @default("EUR")
  pricingMode      String   @default("ONE_TIME") // ONE_TIME | MONTHLY

  // Template specs
  powerConsumption Float? // Watts
  weight           Float? // kg
  defaultUHeight   Int? // default rack height

  // WiFi AP template defaults (v1.4.x) — pre-filled on assets created from the model.
  // Only meaningful for AssetModel.type === 'WIFI_AP', but kept optional to avoid
  // schema branching. Ignored by the frontend for non-WiFi types.
  wifiCoverageRadius Float? // meters — default coverage radius drawn on floor plans
  wifiFrequency      String? // "2.4GHz" | "5GHz" | "6GHz" | "DUAL" | "TRI"
  wifiAntennaType    String? // "OMNI" | "DIRECTIONAL" | "SECTOR"
  wifiTxPowerDbm     Int? // transmit power in dBm

  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets Asset[]

  @@unique([tenantId, name])
  @@index([tenantId, type, isActive])
  @@map("asset_models")
}

model Asset {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  delegationId String?
  delegation   Delegation? @relation(fields: [delegationId], references: [id], onDelete: Restrict)
  siteId       String?
  site         Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  type         String // was AssetType enum — dynamic via EnumLabel
  name         String?
  model        String?
  manufacturer String?
  serialNumber String?
  inventoryTag String?
  status       String      @default("IN_SERVICE") // was AssetStatus enum — dynamic via EnumLabel

  // Model & pricing
  assetModelId     String?
  assetModel       AssetModel? @relation(fields: [assetModelId], references: [id], onDelete: SetNull)
  acquisitionPrice Decimal?    @db.Decimal(10, 2) // purchase price
  monthlyPrice     Decimal?    @db.Decimal(10, 2) // monthly rental/lease
  priceCurrency    String      @default("EUR")

  // Location
  locationText String?

  // Network identity — extracted from former networkInfo JSON in S6 (ADR-018).
  // Indexable for IP-based search; queryable for tenant-wide network audits.
  ip       String?
  mac      String?
  hostname String?
  vlan     String?
  port     String?

  // Rack mounting (optional)
  rackId        String?
  rack          Rack?   @relation(fields: [rackId], references: [id], onDelete: SetNull)
  rackPositionU Int? // Starting U position
  rackHeightU   Int? // Height in U
  rackNotes     String? // Notes for this asset when mounted in rack

  // QR Code
  qrCodeUrl   String? @db.Text // Base64 data URL of QR code image
  qrCodeToken String? // Secure token for QR validation

  // Metadata
  purchaseDate     DateTime?
  warrantyEnd      DateTime?
  weight           Float? // kg
  powerConsumption Float? // Watts
  dutyCyclePercent Int       @default(100) // Effective usage % (0-100) for consumption estimation
  notes            String?   @db.Text

  // WiFi AP coverage (for floor-plan rendering)
  wifiCoverageRadius Float? // meters — used to draw coverage circle on floor plans
  wifiFrequency      String? // "2.4GHz" | "5GHz" | "6GHz" | "DUAL" | "TRI"
  wifiAntennaType    String? // "OMNI" | "DIRECTIONAL" | "SECTOR"
  wifiTxPowerDbm     Int? // transmit power in dBm

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  pins              Pin[]
  tasks             Task[]
  externalRefs      ExternalRef[]
  photos            Photo[]
  movements         AssetMovement[]
  connectivityLinks ConnectivityLink[]
  sdwanRoles        SdwanFirewall[]
  monitorChecks     MonitorCheck[]
  adminLinks        AssetAdminLink[]

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([tenantId, delegationId])
  @@index([tenantId, siteId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, ip])
  @@index([rackId])
  @@map("assets")
}

// Admin URLs (web GUI, SSH jump-host, ticket links) attached to an asset.
// Free-form label/url pairs, ordered for display. Extracted from the former
// Asset.networkInfo.adminLinks JSON-list in S6 (ADR-018).
model AssetAdminLink {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  label     String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([assetId])
  @@map("asset_admin_links")
}

// ============================================================================
// ASSET MOVEMENT HISTORY
// ============================================================================

enum AssetMovementType {
  SITE_CHANGE // Changed site
  RACK_MOUNT // Mounted in rack
  RACK_UNMOUNT // Unmounted from rack
  RACK_MOVE // Moved within rack (position change)
  RACK_CHANGE // Moved to different rack
  STATUS_CHANGE // Status changed
  CREATED // Asset created
}

model AssetMovement {
  id       String            @id @default(cuid())
  tenantId String
  assetId  String
  asset    Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId   String?
  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  type     AssetMovementType

  // Site change tracking
  fromSiteId String?
  fromSite   Site?   @relation("movementFromSite", fields: [fromSiteId], references: [id], onDelete: SetNull)
  toSiteId   String?
  toSite     Site?   @relation("movementToSite", fields: [toSiteId], references: [id], onDelete: SetNull)

  // Rack change tracking
  fromRackId        String?
  fromRack          Rack?   @relation("movementFromRack", fields: [fromRackId], references: [id], onDelete: SetNull)
  toRackId          String?
  toRack            Rack?   @relation("movementToRack", fields: [toRackId], references: [id], onDelete: SetNull)
  fromRackPositionU Int?
  toRackPositionU   Int?

  // Status change tracking
  fromStatus String?
  toStatus   String?

  // Metadata
  notes     String?  @db.Text
  timestamp DateTime @default(now())

  @@index([tenantId, assetId])
  @@index([assetId, timestamp])
  @@map("asset_movements")
}

// ============================================================================
// RACKS (BAIES)
// ============================================================================

enum RackType {
  WALL_MOUNTED
  FLOOR_STANDING
  ENCLOSED_CABINET
}

enum RackStatus {
  IN_SERVICE
  OUT_OF_SERVICE
  PREPARATION
}

model Rack {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId       String
  site         Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name         String
  serialNumber String?
  model        String?
  manufacturer String?
  heightU      Int // 4, 6, 12, 18, 24, 42
  rackType     RackType   @default(FLOOR_STANDING)
  status       RackStatus @default(IN_SERVICE)
  location     String?

  // Specs (JSON)
  specs Json? @db.JsonB // {dimensions, depth, maxLoad, cooling, security, power}

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assets        Asset[]
  pins          Pin[]
  movementsFrom AssetMovement[] @relation("movementFromRack")
  movementsTo   AssetMovement[] @relation("movementToRack")

  @@unique([tenantId, siteId, name])
  @@index([tenantId])
  @@index([tenantId, siteId])
  @@map("racks")
}

// ============================================================================
// FLOOR PLANS & PINS
// ============================================================================

model FloorPlan {
  id          String  @id @default(cuid())
  siteId      String
  site        Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title       String
  version     Int     @default(1)
  planGroupId String? // Groups versions of the same plan together

  // File
  fileUrl  String
  fileSize Int?
  mimeType String?

  // Metadata
  notes      String?  @db.Text
  uploadedBy String
  uploadedAt DateTime @default(now())

  // Scale calibration (for heatmap / measurements)
  scaleMetersPerPixel Float? // Meters per normalized unit (0-1)
  scaleRefLine        Json?  @db.JsonB // {x1,y1,x2,y2,meters} reference line

  // Relations
  pins Pin[]

  @@index([siteId])
  @@index([siteId, version])
  @@index([planGroupId])
  @@map("floor_plans")
}

// PinType enum removed in v1.3 — now dynamic String via EnumLabel

model Pin {
  id          String    @id @default(cuid())
  floorPlanId String
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)

  // Normalized coordinates (0.0 to 1.0)
  x Float
  y Float

  // Type & association
  pinType String // was PinType enum — dynamic via EnumLabel
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  rackId  String?
  rack    Rack?   @relation(fields: [rackId], references: [id], onDelete: Cascade)

  label       String?
  description String? @db.Text
  icon        String?
  color       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([floorPlanId])
  @@index([assetId])
  @@index([rackId])
  @@map("pins")
}

// ============================================================================
// TASKS
// ============================================================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId      String
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assetId     String?
  asset       Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)

  // Assignment
  assignedTo   String?
  assignedUser User?   @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  createdBy    String?
  creator      User?   @relation("CreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  // Scheduling
  dueDate DateTime?

  // TicketLink
  ticketRef    String?
  ticketUrl    String?
  ticketStatus String?

  // Costs (prestations)
  estimatedCost Decimal? @db.Decimal(10, 2)
  actualCost    Decimal? @db.Decimal(10, 2)
  costCurrency  String   @default("EUR")

  // Linked expense (ADR-011) — 1:1, populated when the user opts in to
  // generate an Expense from this task on completion. Symmetric with
  // ConnectivityLink.expenseId.
  expenseId String?
  expense   Expense? @relation("taskExpense", fields: [expenseId], references: [id], onDelete: SetNull)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  photos         Photo[]
  checklistItems TaskChecklistItem[]
  comments       TaskComment[]

  @@index([tenantId])
  @@index([tenantId, siteId])
  @@index([tenantId, status])
  @@index([tenantId, assignedTo])
  @@index([tenantId, dueDate])
  // Kanban hot-path: WHERE tenantId=… AND status=… ORDER BY dueDate
  @@index([tenantId, status, dueDate])
  @@index([expenseId])
  @@map("tasks")
}

model TaskChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  checked   Boolean  @default(false)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([taskId, order])
  @@map("task_checklist_items")
}

model TaskComment {
  id       String  @id @default(cuid())
  taskId   String
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId String
  author   User    @relation("TaskComments", fields: [authorId], references: [id])
  text     String  @db.Text
  // isSystem: true = auto-generated comment (status change, blocking reason, etc.)
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([taskId, createdAt])
  @@map("task_comments")
}

// ============================================================================
// CONTACTS & CONTACT TYPES
// ============================================================================

enum ContactCategory {
  PROVIDER // Fournisseurs externes (telecom, cloud, energie...)
  INTERNAL // Equipes internes (responsable site, gardien...)
  PARTNER // Partenaires IT externes (integrateurs, sous-traitants)
  TECHNICAL // Support technique (NetBox, monitoring)
  EMERGENCY // Contacts urgence
}

model ContactType {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String          @db.VarChar(50) // "Telecommunications", "Plomberie"
  slug     String          @db.VarChar(50) // "telecom", "plomberie"
  category ContactCategory // Categorisation fonctionnelle
  color    String?         @db.VarChar(7) // Hex color "#3b82f6"
  icon     String?         @db.VarChar(50) // Lucide icon name

  isSystem Boolean @default(false) // true = predefini, non supprimable
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contacts Contact[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("contact_types")
}

model Contact {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String @db.VarChar(100)

  // FK vers ContactType
  typeId String
  type   ContactType @relation(fields: [typeId], references: [id])

  // Coordonnees enrichies
  email   String? @db.VarChar(100)
  phone   String? @db.VarChar(50)
  mobile  String? @db.VarChar(50)
  address String? @db.Text

  // Contexte professionnel
  company String? @db.VarChar(100) // Entreprise
  role    String? @db.VarChar(100) // Fonction/role

  // ADR-018 cible D.1 — promoted from former Site.contacts JSON.
  isPrimary Boolean @default(false)

  notes String? @db.Text

  // Rattachement organisationnel (R3)
  // delegationId=null → global (super admin only, visible en lecture partout)
  delegationId String?
  delegation   Delegation? @relation(fields: [delegationId], references: [id], onDelete: SetNull)
  // siteId optionnel — validation R1 : site.delegationId must match delegationId
  siteId       String?
  site         Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  externalRefs     ExternalRef[]
  expensesAsVendor Expense[]     @relation("expenseVendor")

  @@index([tenantId])
  @@index([tenantId, typeId])
  @@index([tenantId, delegationId])
  @@map("contacts")
}

// ============================================================================
// INTEGRATION MAPPINGS
// ============================================================================

model IntegrationMapping {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Source externe
