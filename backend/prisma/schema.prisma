// ============================================================================
// ACCESS OVERRIDES (exceptions ALLOW/DENY par site ou ressource)
// ============================================================================

model AccessOverride {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId   String
  site     Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // "*" = site complet, ou "assets","racks","tasks","plans","contacts","expenses","monitoring"
  resource   String           @default("*")
  effect     OverrideEffect
  permission PermissionLevel? // obligatoire si ALLOW, null si DENY

  label     String?   @db.VarChar(100)
  grantedBy String?
  grantedAt DateTime  @default(now())
  expiresAt DateTime?

  @@unique([tenantId, userId, siteId, resource])
  @@index([tenantId, userId])
  @@index([tenantId, siteId])
  @@map("access_overrides")
}

// ============================================================================
// ENUM LABELS (Custom labels for enums per tenant)
// ============================================================================

model EnumLabel {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enumType  String // "AssetType", "PinType", "AssetStatus"
  enumValue String // "SWITCH", "FIREWALL", etc.
  label     String // Custom display label
  icon      String? // Custom icon name
  color     String? // Custom color hex
  sortOrder Int     @default(0)
  isHidden  Boolean @default(false)
  isBuiltIn Boolean @default(false) // true = valeur système non-supprimable
  isActive  Boolean @default(true) // false = désactivée (pas proposée dans les selects)

  // Per-row semantic flags — meaningful on AssetType rows only.
  //
  // - isConnectivityCapable: the type can terminate a ConnectivityLink (WAN
  //   termination point : ROUTER / FIREWALL / BOX_5G). Switches are LAN, never
  //   WAN — stay false.
  // - isSdwanCapable: the type can run as a node of a SdwanConfig (FIREWALL
  //   primarily, ROUTER in rare setups). Box 5G is a WAN modem, not an SD-WAN
  //   node — stays false.
  isConnectivityCapable Boolean @default(false)
  isSdwanCapable        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, enumType, enumValue])
  @@index([tenantId])
  @@index([tenantId, enumType])
  @@index([tenantId, enumType, isActive])
  @@map("enum_labels")
}

// ============================================================================
// COST ALLOCATION
// ============================================================================

enum ExpenseType {
  EQUIPMENT
  SERVICE
  PROJECT
  CONSUMABLE
  LICENSE
  OTHER
}

enum ExpenseFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

model BillingEntity {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String  @db.VarChar(100)
  code        String  @db.VarChar(20)
  type        String  @db.VarChar(50) // "DIRECTION", "BU", "DELEGATION", "SITE", "SERVICE", "OTHER"
  description String? @db.Text
  isActive    Boolean @default(true)

  // Rattachement organisationnel (R1, R2)
  // delegationId=null → global (super admin, visible partout en lecture)
  delegationId String?
  delegation   Delegation? @relation(fields: [delegationId], references: [id], onDelete: Restrict)
  // siteId optionnel — validation R1 : site.delegationId must match delegationId
  siteId       String?
  site         Site?       @relation(fields: [siteId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  expensesBorne       Expense[]        @relation("bearer")
  allocationsReceived CostAllocation[] @relation("target")
  // Phase 6.7 (D1): optional budgets scoped to this centre de coût.
  budgets             Budget[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, delegationId])
  @@map("billing_entities")
}

model Expense {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // What
  label       String      @db.VarChar(200)
  description String?     @db.Text
  type        ExpenseType @default(OTHER)

  // How much
  totalAmount Float
  currency    String           @default("EUR") @db.VarChar(3)
  frequency   ExpenseFrequency @default(ONE_TIME)

  // When
  dateIncurred DateTime
  dateStart    DateTime?
  dateEnd      DateTime?

  // Who pays (bearer)
  bearerId String
  bearer   BillingEntity @relation("bearer", fields: [bearerId], references: [id], onDelete: Restrict)

  // Rattachement organisationnel (R1, R2 — delegationId OBLIGATOIRE)
  delegationId String
  delegation   Delegation @relation(fields: [delegationId], references: [id], onDelete: Restrict)
  // siteId optionnel — validation R1
  siteId       String?
  site         Site?      @relation(fields: [siteId], references: [id], onDelete: SetNull)

  // Optional links to XCH entities
  assetId     String?
  externalRef String? @db.VarChar(200)

  // Vendor — FK vers Contact (source de verite fournisseurs)
  vendorId      String?
  vendorContact Contact? @relation("expenseVendor", fields: [vendorId], references: [id], onDelete: SetNull)

  // References
  invoiceRef String? @db.VarChar(100)
  poNumber   String? @db.VarChar(50)

  notes     String?  @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Allocations
  allocations CostAllocation[]

  // Linked connectivity (optional reverse for ConnectivityLink.expenseId)
  connectivityLinks ConnectivityLink[]

  // Linked tasks (ADR-011) — reverse for Task.expenseId. Modeled as N:1 by
  // Prisma (mirrors ConnectivityLink) but enforced 1:1 at the service layer
  // (createFromTask refuses if task already has an expense linked).
  tasks Task[] @relation("taskExpense")

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([bearerId])
  @@index([tenantId, delegationId])
  @@index([vendorId])
  // Budget threshold + filtres expenses récents par délégation:
  // WHERE tenantId=… AND delegationId=… AND dateIncurred BETWEEN …
  @@index([tenantId, delegationId, dateIncurred(sort: Desc)])
  @@map("expenses")
}

model CostAllocation {
  id        String  @id @default(cuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  // Target
  targetId String
  target   BillingEntity @relation("target", fields: [targetId], references: [id])

  // Allocation
  percentage Float
  amount     Float

  notes String? @db.Text

  @@index([expenseId])
  @@index([targetId])
  @@map("cost_allocations")
}

// ============================================================================
// BUDGETS
// ============================================================================

enum BudgetPeriod {
  MONTH
  YEAR
}

model Budget {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label           String
  delegationId    String?
  delegation      Delegation?    @relation(fields: [delegationId], references: [id], onDelete: Restrict)
  siteId          String?
  site            Site?          @relation(fields: [siteId], references: [id], onDelete: Restrict)
  // Phase 6.7 (D1, 2026-04-21): a budget can be scoped to a specific centre
  // de coût (BillingEntity). When set, it only matches expenses whose
  // bearerId == billingEntityId. Hierarchy is typically:
  //   Budget Délégation (no billingEntityId) → Budget CdC (billingEntityId set)
  // A CdC without its own budget just consumes the parent delegation budget.
  // Restrict on delete: if a CdC is deleted while a budget targets it,
  // refuse — forces the user to reassign the budget first.
  billingEntityId String?
  billingEntity   BillingEntity? @relation(fields: [billingEntityId], references: [id], onDelete: Restrict)
  expenseType     String? // "EQUIPMENT" | "SERVICE" | ... (matches ExpenseType)
  period          BudgetPeriod   @default(YEAR)
  startDate       DateTime
  endDate         DateTime
  amount          Decimal        @db.Decimal(12, 2)
  currency        String         @default("EUR")
  notes           String?        @db.Text

  // Sub-budget hierarchy (top-down model):
  // - Parent budget fixes the total envelope.
  // - Children sub-divide that envelope (Σ(children.amount) must not exceed parent.amount,
  //   validated at service level; remaining = "non-alloué").
  // - Parent period must wrap children periods.
  // onDelete Restrict: deleting a parent with children is refused — move or
  // delete children first, keeps the accounting trail intact.
  parentId String?
  parent   Budget?  @relation("BudgetHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Budget[] @relation("BudgetHierarchy")

  // Alert threshold (percentage). When Σ(spent for this budget) crosses this
  // percentage of `amount`, a UserNotification is emitted to the budget owner
  // (delegation managers + super-admins). alertsEnabled = false disables it
  // entirely even if the threshold value stays set.
  alertsEnabled     Boolean @default(true)
  alertThresholdPct Int     @default(80) // 1..100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, startDate, endDate])
  @@index([tenantId, delegationId])
  @@index([parentId])
  @@index([billingEntityId])
  @@map("budgets")
}

// ============================================================================
// CONNECTIVITY LINKS (structured replacement of Site.connectivity JSON)
// ============================================================================

enum ConnectivityRole {
  PRIMARY
  BACKUP
  OTHER
}

model ConnectivityLink {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId   String
  site     Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  role          ConnectivityRole @default(PRIMARY)
  provider      String // ISP name ("Orange", "SFR", "Starlink")
  type          String // "FIBER" | "ADSL" | "4G" | "5G" | "STARLINK" | ...
  bandwidthDown Int? // Mbps
  bandwidthUp   Int? // Mbps
  publicIp      String?
  monthlyPrice  Decimal?         @db.Decimal(10, 2)
  currency      String           @default("EUR")
  startDate     DateTime?
  endDate       DateTime?
  contractRef   String?
  notes         String?          @db.Text

  // Equipment that terminates this link (router, firewall, 5G box, ...).
  // Optional: some links are abstract (fiber drop not yet cabled to a box).
  // Filtering of eligible asset types is driven by EnumLabel.isConnectivityCapable.
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  // ConnectivityLink.monitorName + status removed in ADR-016 — superseded by
  // the FK MonitorCheck[] (read MonitorCheck.lastStatus via the relation).

  // Linked recurring expense (optional)
  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Native monitoring (ADR-014)
  monitorChecks MonitorCheck[]

  @@index([tenantId, siteId])
  @@index([tenantId, role])
  @@index([assetId])
  @@map("connectivity_links")
}

// ============================================================================
// SD-WAN
// ============================================================================
// One SD-WAN configuration per site (1:1). Firewalls attached to a config are
// the physical/virtual appliances realising the overlay (active/passive HA,
// or peers in a full mesh). Health aggregation uses these rows to derive the
// SD-WAN status from the underlying firewall monitors. Phase 6.6 — replaces
// the legacy Site.connectivity.sdwan JSON blob dropped in phase 6.5.

model SdwanConfig {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  siteId String @unique
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  enabled     Boolean @default(true)
  provider    String? // "Fortinet SD-WAN", "Cisco Meraki", "VeloCloud", ...
  // SdwanConfig.monitorName + status removed in ADR-016 — overlay status is
  // derived from the attached firewalls' MonitorChecks (HealthAggregationService).
  notes       String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firewalls SdwanFirewall[]

  @@index([tenantId])
  @@map("sdwan_configs")
}

model SdwanFirewall {
  id            String      @id @default(cuid())
  sdwanConfigId String
  sdwanConfig   SdwanConfig @relation(fields: [sdwanConfigId], references: [id], onDelete: Cascade)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  role String? // 'active' | 'passive' | 'peer' — free-form label, semantics up to the provider

  createdAt DateTime @default(now())

  @@unique([sdwanConfigId, assetId])
  @@index([sdwanConfigId])
  @@index([assetId])
  @@map("sdwan_firewalls")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

/// ADR-020 — supported channel kinds. Adding a new one (Slack, Discord,
/// Pagerduty…) requires : (1) extend this enum, (2) add a sender in
/// modules/notifications/channels/, (3) NotificationProcessor route.
enum NotificationChannelKind {
  EMAIL
  TEAMS
}

/// ADR-020 — events that can trigger notifications. Mirror of
/// NotificationEventType TS enum (notification-events.ts). Keep in sync.
enum NotificationEventType {
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  SITE_STATUS_CHANGED
  ASSET_CRITICAL
  MONITOR_DOWN
  MONITOR_UP
  USER_INVITED
  PASSWORD_RESET
}

/// Notification channels (ADR-020) — typed split of the former
/// NotificationConfig.channels JSON. One row per (tenant, delegation, kind).
/// Inheritance : delegation row > global row (delegationId=null) > defaults.
model NotificationChannel {
  id           String                  @id @default(cuid())
  tenantId     String
  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  delegationId String?
  delegation   Delegation?             @relation(fields: [delegationId], references: [id], onDelete: Cascade)

  kind         NotificationChannelKind
  enabled      Boolean                 @default(true)

  /// EMAIL only: comma-separable list of recipient addresses.
  recipients   String[]                @default([])
  /// TEAMS only: incoming-webhook URL — encrypted-at-rest (ADR-019,
  /// CryptoService.encryptIfPlain at write, decryptOrLegacy at read).
  webhookUrl   String?
  /// Non-sensitive options only (formatting, future per-channel flags).
  /// ADR-020 rule : NEVER store secrets here — use scalar columns.
  config       Json?                   @db.JsonB

  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  // ADR-020 §C — Plain @@unique (NULLS DISTINCT par défaut PG) couvre
  // les rows avec delegationId NOT NULL. Un partial unique index nommé
  // `notification_channels_global_uniq` ajouté en migration 7 ferme le
  // trou des rows globales (delegationId IS NULL). Voir migration SQL.
  @@unique([tenantId, delegationId, kind])
  @@index([tenantId])
  @@map("notification_channels")
}

/// Notification rules (ADR-020) — typed split of the former
/// NotificationConfig.events JSON. One row per (tenant, delegation, eventType).
/// Same inheritance pattern as NotificationChannel.
model NotificationRule {
  id           String                      @id @default(cuid())
  tenantId     String
  tenant       Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  delegationId String?
  delegation   Delegation?                 @relation(fields: [delegationId], references: [id], onDelete: Cascade)

  eventType    NotificationEventType
  channels     NotificationChannelKind[]   @default([])
  enabled      Boolean                     @default(true)

  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  // ADR-020 §C — voir commentaire NotificationChannel. Partial unique
  // index `notification_rules_global_uniq` en migration 7.
  @@unique([tenantId, delegationId, eventType])
  @@index([tenantId, eventType])
  @@map("notification_rules")
}

/// Journal des notifications envoyees (audit) (R12)
model NotificationLog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Type d'evenement (TASK_ASSIGNED, SITE_STATUS_CHANGED, etc.)
  eventType    String  @db.VarChar(50)
  /// Canal utilise (email, teams)
  channel      String  @db.VarChar(20)
  /// Delegation qui a declenche
  delegationId String?

  /// Destinataire (email ou webhook URL)
  recipient    String
  /// Sujet/titre
  subject      String
  /// Succes ou echec
  success      Boolean @default(true)
  /// Message d'erreur si echec
  errorMessage String? @db.Text

  /// Contexte de l'evenement (JSON: entityId, entityType, siteId, details...)
  context Json? @db.JsonB

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, eventType])
  @@map("notification_logs")
}

/// In-app notification inbox per user (R12b)
model UserNotification {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  String  @db.VarChar(60) // TASK_ASSIGNED | WARRANTY_EXPIRING | TASK_DUE_SOON | ...
  title String
  body  String? @db.Text
  link  String? // relative URL inside the app

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([tenantId, createdAt])
  @@map("user_notifications")
}

// ============================================================================
// NATIVE MONITORING (ADR-014)
// ============================================================================
// Document storage portals attached to a site. ADR-018 cible D.3 — replaces
// the former Site.emplacements JSON-list. `type` is an enum; URL/description
// stay free-form text.
enum EmplacementType {
  SMB
  SHAREPOINT
}

model SiteEmplacement {
  id          String          @id @default(cuid())
  siteId      String
  site        Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type        EmplacementType
  url         String
  description String?
  order       Int             @default(0)
  createdAt   DateTime        @default(now())

  @@index([siteId])
  @@map("site_emplacements")
}

// Aggregated health snapshot per site, recomputed by HealthAggregationService
// on every monitor pulse. ADR-018 — replaces Site.metadata.healthBreakdown JSON.
// `componentsJson` stays JSON because it's an ephemeral cache rewritten every
// ~30s; normalising would mean DELETE+INSERT N rows per pulse for zero query
// gain (cf. ADR-018 Décision E).
model SiteHealthSnapshot {
  siteId         String       @id
  site           Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  overall        HealthStatus
  componentsJson Json         @db.JsonB
  computedAt     DateTime

  @@index([overall])
  @@map("site_health_snapshots")
}

// Native probes (ICMP/HTTP/TCP) executed by the dedicated worker container.
// Polymorphic targets via separate FKs (siteId/assetId/linkId) — exactly one
// must be non-null, enforced at app-service-layer AND by a SQL CHECK constraint
// applied via migration 1_post_push_constraints (defense in depth, ADR-017).
// HTTP-specific config lives in MonitorHttpConfig (1:0-1) — zero JSON.

enum MonitorKind {
  ICMP
  HTTP
  TCP
}

enum MonitorStatus {
  UP
  DOWN
  UNKNOWN
}

enum HttpMethod {
  GET
  HEAD
  POST
}

model MonitorCheck {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Polymorphic target — exactly one of siteId / assetId / linkId is non-null
  // (enforced by app service + SQL CHECK constraint in migration 1_post_push_constraints).
  siteId  String?
  site    Site?             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assetId String?
  asset   Asset?            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  linkId  String?
  link    ConnectivityLink? @relation(fields: [linkId], references: [id], onDelete: Cascade)

  kind        MonitorKind
  target      String // host / IP / URL — semantics depend on kind
  targetPort  Int? // required when kind = TCP, ignored otherwise
  intervalSec Int         @default(300) // 60..3600

  enabled       Boolean       @default(true)
  lastCheckedAt DateTime?
  nextCheckAt   DateTime?
  lastStatus    MonitorStatus @default(UNKNOWN)

  // HTTP-specific config (1:0-1, zero JSON). Null for ICMP / TCP.
  httpConfig MonitorHttpConfig?

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results MonitorResult[]

  // Scheduler hot-path: WHERE enabled=true AND nextCheckAt<=now()
  @@index([tenantId, enabled, nextCheckAt])
  @@index([siteId])
  @@index([assetId])
  @@index([linkId])
  @@map("monitor_checks")
}

model MonitorHttpConfig {
  id      String       @id @default(cuid())
  checkId String       @unique
  check   MonitorCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  method               HttpMethod @default(GET)
  expectedStatus       Int        @default(200)
  expectedBodyContains String?
  followRedirects      Boolean    @default(true)
  timeoutMs            Int        @default(5000)

  // Custom headers intentionally left out (YAGNI) — add MonitorHttpHeader[]
  // table the day a pilot needs them.

  @@map("monitor_http_configs")
}

model MonitorResult {
  id      String       @id @default(cuid())
  checkId String
  check   MonitorCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  status     MonitorStatus
  responseMs Int?
  error      String?       @db.Text
  checkedAt  DateTime      @default(now())

  // Hot path: latest results for a given check, descending.
  @@index([checkId, checkedAt(sort: Desc)])
  @@map("monitor_results")
}
