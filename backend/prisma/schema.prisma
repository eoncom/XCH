// XCH - Prisma Schema
// PostgreSQL 15+ with PostGIS extension

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ============================================================================
// TENANT & AUTH
// ============================================================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

model Tenant {
  id       String       @id @default(cuid())
  name     String
  subdomain String      @unique
  status   TenantStatus @default(ACTIVE)

  // Branding
  logoUrl      String?
  primaryColor String? @default("#0070f3")

  // Configuration (JSON)
  config Json? @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users               User[]
  authProviders        AuthProvider[]
  divisions            Division[]
  delegations          Delegation[]
  sites                Site[]
  assets               Asset[]
  racks                Rack[]
  tasks                Task[]
  contacts             Contact[]
  contactTypes         ContactType[]
  integrationMappings  IntegrationMapping[]
  auditLogs            AuditLog[]
  enumLabels           EnumLabel[]
  billingEntities      BillingEntity[]
  expenses             Expense[]

  @@index([status])
  @@map("tenants")
}

enum UserRole {
  ADMIN
  MANAGER
  TECHNICIEN
  VIEWER
}

model User {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identity
  email        String
  passwordHash String? // NULL if external auth only

  // Profile
  name      String
  phone     String?
  avatarUrl String?

  // Permissions
  role   UserRole @default(VIEWER)
  active Boolean  @default(true)

  // External auth
  externalId   String? // OIDC 'sub' or SAML nameID
  authProvider String  @default("local") // local, oidc, saml

  // TOTP 2FA
  totpSecret      String?
  totpEnabled     Boolean   @default(false)
  totpBackupCodes String[]

  // Account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Metadata
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  assignedTasks  Task[]          @relation("AssignedTo")
  createdTasks   Task[]          @relation("CreatedBy")
  taskComments   TaskComment[]   @relation("TaskComments")
  auditLogs      AuditLog[]
  photos         Photo[]
  siteAccess     UserSiteAccess[] // DEPRECATED — replaced by scopes + accessGrants
  scopes         UserScope[]
  accessGrants   AccessGrant[]
  assetMovements AssetMovement[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, externalId])
  @@index([tenantId, role])
  @@map("users")
}

enum AuthProviderType {
  OIDC
  SAML
}

model AuthProvider {
  id       String           @id @default(cuid())
  tenantId String
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type     AuthProviderType
  name     String
  enabled  Boolean          @default(false)

  // OIDC config
  issuer       String?
  clientId     String?
  clientSecret String? // Encrypted at-rest
  scopes       String[] @default(["openid", "profile", "email"])

  // SAML config (future)
  samlConfig Json? @db.JsonB

  // Attribute mapping
  attributeMap Json? @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type, name])
  @@index([tenantId, enabled])
  @@map("auth_providers")
}

// ============================================================================
// ORGANISATION (Division → Délégation → Site)
// ============================================================================

model Division {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String @db.VarChar(100)
  code     String @db.VarChar(20)
  color    String? @db.VarChar(7) // Hex color for visual grouping
  notes    String? @db.Text
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  delegations Delegation[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("divisions")
}

model Delegation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  divisionId String
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  name     String @db.VarChar(100)
  code     String @db.VarChar(20)
  notes    String? @db.Text
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sites Site[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([divisionId])
  @@map("delegations")
}

// ============================================================================
// SITES (CHANTIERS)
// ============================================================================

enum SiteStatus {
  PREPARATION
  ACTIVE
  CLOSED
}

enum HealthStatus {
  HEALTHY
  WARNING
  CRITICAL
  UNKNOWN
}

model Site {
  id       String     @id @default(cuid())
  tenantId String
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  delegationId String
  delegation   Delegation @relation(fields: [delegationId], references: [id], onDelete: Restrict)

  code     String
  name     String
  status   SiteStatus @default(ACTIVE)

  // Location
  address    String
  city       String
  postalCode String?
  country    String  @default("France")

  // PostGIS geometry - POINT(longitude, latitude)
  coordinates Unsupported("geometry(Point,4326)")?

  // Contacts (JSON array)
  contacts Json? @db.JsonB // [{name, phone, email, role, isPrimary}]

  // Access notes (JSON)
  accessNotes Json? @db.JsonB // {schedules, badges, procedures, safety}

  // Connectivity (JSON)
  connectivity Json? @db.JsonB // {primary: {type, provider, ref}, backup, cutProcedure}

  // Document Emplacements (JSON array)
  emplacements Json? @db.JsonB // [{type: 'smb'|'sharepoint', url, description}]

  // Governance Documents Reference
  governanceDocsRef String? // URL to "Référentiel droits documents"

  // Monitoring
  monitoringEnabled Boolean      @default(true)

  // Health
  healthStatus    HealthStatus @default(UNKNOWN)
  lastHealthCheck DateTime?

  // Metadata
  metadata  Json?    @db.JsonB // {serverInfo: {smbPath, sharepointUrl, gedUrl, accessRightsUrl, notes}}
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assets              Asset[]
  racks               Rack[]
  floorPlans          FloorPlan[]
  tasks               Task[]
  externalRefs        ExternalRef[]
  photos              Photo[]
  userAccess          UserSiteAccess[]
  movementsFrom       AssetMovement[] @relation("movementFromSite")
  movementsTo         AssetMovement[] @relation("movementToSite")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, healthStatus])
  @@index([delegationId])
  @@map("sites")
}

// ============================================================================
// ASSETS (ÉQUIPEMENTS)
// ============================================================================

enum AssetType {
  PRINTER
  IPAD
  TABLET
  SWITCH
  FIREWALL
  ROUTER
  WIFI_AP
  ACCESS_POINT
  TEAMS_ROOM
  WEBCAM
  DISPLAY
  CAMERA
  SERVER
  CABLE
  PATCH_PANEL
  PDU
  BOX_5G
  OTHER
}

enum AssetStatus {
  IN_SERVICE
  OUT_OF_SERVICE
  IN_TRANSIT
  STOCK
  RETIRED
}

model Asset {
  id       String     @id @default(cuid())
  tenantId String
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId   String?
  site     Site?      @relation(fields: [siteId], references: [id], onDelete: SetNull)
  type     AssetType
  name     String?
  model    String?
  manufacturer String?
  serialNumber String?
  inventoryTag String?
  status       AssetStatus @default(IN_SERVICE)

  // Location
  locationText String?

  // Network info (JSON)
  networkInfo Json? @db.JsonB // {ip, mac, hostname, vlan, port}

  // Rack mounting (optional)
  rackId        String?
  rack          Rack?   @relation(fields: [rackId], references: [id], onDelete: SetNull)
  rackPositionU Int? // Starting U position
  rackHeightU   Int? // Height in U
  rackNotes     String? // Notes for this asset when mounted in rack

  // QR Code
  qrCodeUrl   String?   @db.Text  // Base64 data URL of QR code image
  qrCodeToken String?             // Secure token for QR validation

  // Metadata
  purchaseDate     DateTime?
  warrantyEnd      DateTime?
  weight           Float? // kg
  powerConsumption Float? // Watts
  notes            String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  pins         Pin[]
  tasks        Task[]
  externalRefs ExternalRef[]
  photos       Photo[]
  movements    AssetMovement[]

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([tenantId, siteId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([rackId])
  @@map("assets")
}

// ============================================================================
// ASSET MOVEMENT HISTORY
// ============================================================================

enum AssetMovementType {
  SITE_CHANGE        // Changed site
  RACK_MOUNT         // Mounted in rack
  RACK_UNMOUNT       // Unmounted from rack
  RACK_MOVE          // Moved within rack (position change)
  RACK_CHANGE        // Moved to different rack
  STATUS_CHANGE      // Status changed
  CREATED            // Asset created
}

model AssetMovement {
  id        String            @id @default(cuid())
  tenantId  String
  assetId   String
  asset     Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      AssetMovementType

  // Site change tracking
  fromSiteId String?
  fromSite   Site?  @relation("movementFromSite", fields: [fromSiteId], references: [id], onDelete: SetNull)
  toSiteId   String?
  toSite     Site?  @relation("movementToSite", fields: [toSiteId], references: [id], onDelete: SetNull)

  // Rack change tracking
  fromRackId      String?
  fromRack        Rack?  @relation("movementFromRack", fields: [fromRackId], references: [id], onDelete: SetNull)
  toRackId        String?
  toRack          Rack?  @relation("movementToRack", fields: [toRackId], references: [id], onDelete: SetNull)
  fromRackPositionU Int?
  toRackPositionU   Int?

  // Status change tracking
  fromStatus String?
  toStatus   String?

  // Metadata
  notes     String?   @db.Text
  timestamp DateTime  @default(now())

  @@index([tenantId, assetId])
  @@index([assetId, timestamp])
  @@map("asset_movements")
}

// ============================================================================
// RACKS (BAIES)
// ============================================================================

enum RackType {
  WALL_MOUNTED
  FLOOR_STANDING
  ENCLOSED_CABINET
}

enum RackStatus {
  IN_SERVICE
  OUT_OF_SERVICE
  PREPARATION
}

model Rack {
  id       String     @id @default(cuid())
  tenantId String
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId   String
  site     Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name     String
  serialNumber String?
  model        String?
  manufacturer String?
  heightU      Int // 4, 6, 12, 18, 24, 42
  rackType     RackType   @default(FLOOR_STANDING)
  status       RackStatus @default(IN_SERVICE)
  location     String?

  // Specs (JSON)
  specs Json? @db.JsonB // {dimensions, depth, maxLoad, cooling, security, power}

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assets         Asset[]
  pins           Pin[]
  movementsFrom  AssetMovement[] @relation("movementFromRack")
  movementsTo    AssetMovement[] @relation("movementToRack")

  @@unique([tenantId, siteId, name])
  @@index([tenantId])
  @@index([tenantId, siteId])
  @@map("racks")
}

// ============================================================================
// FLOOR PLANS & PINS
// ============================================================================

model FloorPlan {
  id         String  @id @default(cuid())
  siteId     String
  site       Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title      String
  version    Int     @default(1)
  planGroupId String? // Groups versions of the same plan together

  // File
  fileUrl  String
  fileSize Int?
  mimeType String?

  // Metadata
  notes      String?  @db.Text
  uploadedBy String
  uploadedAt DateTime @default(now())

  // Scale calibration (for heatmap / measurements)
  scaleMetersPerPixel Float?  // Meters per normalized unit (0-1)
  scaleRefLine        Json?   @db.JsonB // {x1,y1,x2,y2,meters} reference line

  // Relations
  pins Pin[]

  @@index([siteId])
  @@index([siteId, version])
  @@index([planGroupId])
  @@map("floor_plans")
}

enum PinType {
  SWITCH
  FIREWALL
  ACCESS_POINT
  PRINTER
  RACK
  CAMERA
  PATCH_PANEL
  RJ45
  NRO
  ROUTER
  TEAMS_ROOM
  WEBCAM
  DISPLAY
  SERVER
  PDU
  BOX_5G
  OTHER
}

model Pin {
  id          String    @id @default(cuid())
  floorPlanId String
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)

  // Normalized coordinates (0.0 to 1.0)
  x Float
  y Float

  // Type & association
  pinType PinType
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  rackId  String?
  rack    Rack?   @relation(fields: [rackId], references: [id], onDelete: Cascade)

  label       String?
  description String? @db.Text
  icon        String?
  color       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([floorPlanId])
  @@index([assetId])
  @@index([rackId])
  @@map("pins")
}

// ============================================================================
// TASKS
// ============================================================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId      String
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assetId     String?
  asset       Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)

  // Assignment
  assignedTo   String?
  assignedUser User?   @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  createdBy    String
  creator      User    @relation("CreatedBy", fields: [createdBy], references: [id])

  // Scheduling
  dueDate DateTime?

  // TicketLink
  ticketRef    String?
  ticketUrl    String?
  ticketStatus String?

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  photos         Photo[]
  checklistItems TaskChecklistItem[]
  comments       TaskComment[]

  @@index([tenantId])
  @@index([tenantId, siteId])
  @@index([tenantId, status])
  @@index([tenantId, assignedTo])
  @@index([tenantId, dueDate])
  @@map("tasks")
}

model TaskChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  checked   Boolean  @default(false)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([taskId, order])
  @@map("task_checklist_items")
}

model TaskComment {
  id       String @id @default(cuid())
  taskId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("TaskComments", fields: [authorId], references: [id])
  text     String @db.Text
  // isSystem: true = auto-generated comment (status change, blocking reason, etc.)
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([taskId, createdAt])
  @@map("task_comments")
}

// ============================================================================
// CONTACTS & CONTACT TYPES (remplace PROVIDERS)
// ============================================================================

enum ContactCategory {
  PROVIDER       // Fournisseurs externes (télécom, cloud, énergie...)
  INTERNAL       // Équipes internes (responsable site, gardien...)
  PARTNER        // Partenaires IT externes (intégrateurs, sous-traitants)
  TECHNICAL      // Support technique (NetBox, monitoring)
  EMERGENCY      // Contacts urgence
}

model ContactType {
  id       String          @id @default(cuid())
  tenantId String
  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String          @db.VarChar(50)    // "Télécommunications", "Plomberie"
  slug     String          @db.VarChar(50)    // "telecom", "plomberie"
  category ContactCategory                    // Catégorisation fonctionnelle
  color    String?         @db.VarChar(7)     // Hex color "#3b82f6"
  icon     String?         @db.VarChar(50)    // Lucide icon name

  isSystem Boolean         @default(false)    // true = prédéfini, non supprimable
  isActive Boolean         @default(true)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  contacts Contact[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("contact_types")
}

model Contact {
  id       String      @id @default(cuid())
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String      @db.VarChar(100)

  // FK vers ContactType (remplace l'ancien enum ProviderType)
  typeId   String
  type     ContactType @relation(fields: [typeId], references: [id])

  // Coordonnées enrichies
  email    String?     @db.VarChar(100)
  phone    String?     @db.VarChar(50)
  mobile   String?     @db.VarChar(50)
  address  String?     @db.Text

  // Contexte professionnel
  company  String?     @db.VarChar(100)   // Entreprise
  role     String?     @db.VarChar(100)   // Fonction/rôle

  notes    String?     @db.Text

  isActive Boolean     @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  externalRefs ExternalRef[]

  @@index([tenantId])
  @@index([tenantId, typeId])
  @@map("contacts")
}

// ============================================================================
// INTEGRATION MAPPINGS (générique pour toutes intégrations)
// ============================================================================

model IntegrationMapping {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Source externe
  provider      String   // "netbox", "uptime_kuma", "checkmk"
  entityType    String   // "contact_group", "site_status", "device_role"
  externalId    String   // ID ou slug dans le système externe
  externalLabel String   // Nom affiché (cache)

  // Cible XCH
  targetType    String   // "contact_type", "site_status", "asset_type"
  targetId      String   // ID de l'entité XCH cible

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, provider, entityType, externalId])
  @@index([tenantId, provider, entityType])
  @@map("integration_mappings")
}

// ============================================================================
// PHOTOS & ATTACHMENTS
// ============================================================================

enum EntityType {
  SITE
  ASSET
  TASK
  RACK
  CONTACT
}

model Photo {
  id         String     @id @default(cuid())
  entityType EntityType
  entityId   String

  // Polymorphic relations
  site  Site?  @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_siteId_fkey")
  asset Asset? @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_assetId_fkey")
  task  Task?  @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_taskId_fkey")

  // File
  fileUrl  String
  fileName String
  fileSize Int?
  mimeType String

  // Metadata
  caption    String?
  uploadedBy String
  uploader   User    @relation(fields: [uploadedBy], references: [id])
  uploadedAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([uploadedAt])
  @@map("photos")
}

// ============================================================================
// EXTERNAL REFS (INTEGRATIONS)
// ============================================================================

model ExternalRef {
  id         String     @id @default(cuid())
  entityType EntityType
  entityId   String

  // Polymorphic relations
  site    Site?    @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "external_refs_siteId_fkey")
  asset   Asset?   @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "external_refs_assetId_fkey")
  contact Contact? @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "external_refs_contactId_fkey")

  // Integration provider
  provider    String // netbox, uptime_kuma, fortimanager
  externalId  String
  externalUrl String?

  // Metadata (JSON)
  metadata Json?     @db.JsonB
  lastSync DateTime?
  createdAt DateTime @default(now())

  @@unique([entityType, entityId, provider])
  @@index([entityType, entityId])
  @@index([provider])
  @@map("external_refs")
}

// ============================================================================
// ATTACHMENTS
// ============================================================================

model Attachment {
  id       String @id @default(cuid())
  tenantId String

  // Polymorphic relation (assetId, taskId, rackId, or siteId)
  assetId String?
  taskId  String?
  rackId  String?
  siteId  String?

  // File metadata
  filename         String
  originalFilename String
  size             Int
  mimetype         String
  path             String // MinIO path: attachments/{tenantId}/{entityType}/{entityId}/{timestamp}_{filename}

  // Optional metadata
  description String?
  category    String? // spec, invoice, photo, report, manual, other

  // Audit
  uploadedBy String
  uploadedAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, assetId])
  @@index([tenantId, taskId])
  @@index([tenantId, rackId])
  @@index([tenantId, siteId])
  @@map("attachments")
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // CREATE, UPDATE, DELETE
  entityType String
  entityId   String?

  // Changes (JSON)
  changes Json? @db.JsonB // {before: {...}, after: {...}}

  // Context
  ipAddress String?
  userAgent String?

  timestamp DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, timestamp])
  @@index([tenantId, userId])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

// ============================================================================
// SITE ACCESS CONTROL (Per-user site permissions)
// ============================================================================

enum SiteAccessLevel {
  READ
  WRITE
}

model UserSiteAccess {
  id       String          @id @default(cuid())
  tenantId String

  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId   String
  site     Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)

  accessLevel SiteAccessLevel @default(READ)
  resourcePermissions Json? @db.JsonB // Per-resource permission overrides: {"assets":"WRITE","tasks":"READ","floorPlans":"NONE",...}

  grantedBy   String?
  grantedAt   DateTime     @default(now())

  @@unique([userId, siteId])
  @@index([tenantId])
  @@index([userId])
  @@index([siteId])
  @@map("user_site_access")
}

// ============================================================================
// USER SCOPES & ACCESS GRANTS (replaces UserSiteAccess for permission resolution)
// ============================================================================

enum ScopeType {
  TENANT     // All sites in the tenant
  DIVISION   // All sites in a division
  DELEGATION // All sites in a delegation
  SITE       // A specific site
}

model UserScope {
  id       String    @id @default(cuid())
  tenantId String
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  scopeType ScopeType
  scopeId   String?   // null if TENANT, otherwise divisionId/delegationId/siteId

  grantedBy String?
  grantedAt DateTime  @default(now())

  @@unique([userId, scopeType, scopeId])
  @@index([tenantId, userId])
  @@map("user_scopes")
}

enum AccessScope {
  ALL_SITES  // All sites in the tenant
  DIVISION   // All sites in a division
  DELEGATION // All sites in a delegation
  SITE       // A specific site
}

model AccessGrant {
  id       String      @id @default(cuid())
  tenantId String
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  scope    AccessScope
  scopeId  String?     // divisionId, delegationId, or siteId depending on scope

  resourcePermissions Json @db.JsonB // {"floorPlans":"READ","tasks":"READ",...} — ADDITIVE ONLY
  label    String?     @db.VarChar(100) // e.g. "Partenaire plans"

  grantedBy String?
  grantedAt DateTime   @default(now())
  expiresAt DateTime?  // Temporary access

  @@index([tenantId, userId])
  @@map("access_grants")
}

// ============================================================================
// CASBIN (RBAC/ABAC)
// ============================================================================

model CasbinRule {
  id    Int     @id @default(autoincrement())
  ptype String // 'p' or 'g'
  v0    String?
  v1    String?
  v2    String?
  v3    String?
  v4    String?
  v5    String?

  @@index([ptype, v0, v1, v2, v3])
  @@map("casbin_rule")
}

// ============================================================================
// ENUM LABELS (Custom labels for enums per tenant)
// ============================================================================

model EnumLabel {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enumType  String  // "AssetType", "PinType", "AssetStatus"
  enumValue String  // "SWITCH", "FIREWALL", etc.
  label     String  // Custom display label
  icon      String? // Custom icon name
  color     String? // Custom color hex
  sortOrder Int     @default(0)
  isHidden  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, enumType, enumValue])
  @@index([tenantId])
  @@index([tenantId, enumType])
  @@map("enum_labels")
}

// ============================================================================
// COST ALLOCATION (Phase C)
// ============================================================================

enum ExpenseType {
  EQUIPMENT
  SERVICE
  PROJECT
  CONSUMABLE
  LICENSE
  OTHER
}

enum ExpenseFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

model BillingEntity {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String  @db.VarChar(100)
  code        String  @db.VarChar(20)
  type        String  @db.VarChar(50) // "DIRECTION", "BU", "DELEGATION", "SITE", "SERVICE", "OTHER"
  description String? @db.Text
  isActive    Boolean @default(true)

  // Optional links to org hierarchy (informational, not constraining)
  divisionId   String?
  delegationId String?
  siteId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  expensesBorne       Expense[]        @relation("bearer")
  allocationsReceived CostAllocation[] @relation("target")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("billing_entities")
}

model Expense {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // What
  label       String       @db.VarChar(200)
  description String?      @db.Text
  type        ExpenseType  @default(OTHER)

  // How much
  totalAmount Float
  currency    String           @default("EUR") @db.VarChar(3)
  frequency   ExpenseFrequency @default(ONE_TIME)

  // When
  dateIncurred DateTime
  dateStart    DateTime?
  dateEnd      DateTime?

  // Who pays (bearer)
  bearerId String
  bearer   BillingEntity @relation("bearer", fields: [bearerId], references: [id])

  // Optional links to XCH entities
  siteId      String?
  assetId     String?
  externalRef String? @db.VarChar(200)

  // Vendor reference
  vendor     String? @db.VarChar(100)
  invoiceRef String? @db.VarChar(100)
  poNumber   String? @db.VarChar(50)

  notes     String? @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Allocations
  allocations CostAllocation[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([bearerId])
  @@map("expenses")
}

model CostAllocation {
  id        String  @id @default(cuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  // Target
  targetId String
  target   BillingEntity @relation("target", fields: [targetId], references: [id])

  // Allocation
  percentage Float
  amount     Float

  notes String? @db.Text

  @@index([expenseId])
  @@index([targetId])
  @@map("cost_allocations")
}
