  @@unique([tenantId, provider, entityType, externalId])
  @@index([tenantId, provider, entityType])
  @@map("integration_mappings")
}

// ============================================================================
// PHOTOS & ATTACHMENTS
// ============================================================================

enum EntityType {
  SITE
  ASSET
  TASK
  RACK
  CONTACT
}

model Photo {
  id         String     @id @default(cuid())
  entityType EntityType
  entityId   String

  // Polymorphic relations
  site  Site?  @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_siteId_fkey")
  asset Asset? @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_assetId_fkey")
  task  Task?  @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "photos_taskId_fkey")

  // File
