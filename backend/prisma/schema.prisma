  // Polymorphic relation (assetId, taskId, rackId, or siteId)
  assetId String?
  taskId  String?
  rackId  String?
  siteId  String?

  // File metadata
  filename         String
  originalFilename String
  size             Int
  mimetype         String
  path             String // MinIO path: attachments/{tenantId}/{entityType}/{entityId}/{timestamp}_{filename}

  // Optional metadata
