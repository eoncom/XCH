# ===== DATABASE =====
# Replace <PASSWORD> with the value of POSTGRES_PASSWORD from the root .env.
# Example : DATABASE_URL="postgresql://xch_user:Z7K8x...A==@postgres:5432/xch_dev"
DATABASE_URL="postgresql://xch_user:<PASSWORD>@postgres:5432/xch_dev"

# ===== APP =====
NODE_ENV=development
PORT=3000

# ===== FRONTEND =====
# Only needed if frontend is on a different origin (CORS)
# When behind nginx proxy, leave empty
FRONTEND_URL=

# ===== COOKIES =====
# Domain for cookies (leave empty for localhost, set to .yourdomain.com for production)
COOKIE_DOMAIN=
# Set to true when using HTTPS in production
COOKIE_SECURE=false

# ===== JWT =====
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ===== ADR-019 — Secrets at-rest (AES-256-GCM) =====
# 32 bytes random in base64 — generate with: openssl rand -base64 32
# Required in prod ; missing in dev → fail-soft (encrypt/decrypt no-op).
# IMPORTANT : losing this key without backup makes encrypted columns
# (TenantSsoConfig.clientSecret, TenantIntegrationConfig.netboxToken,
# User.totpSecret, NotificationConfig.channels.teams.webhookUrl)
# unreadable — reset+seed required.
XCH_MASTER_KEY=

# ===== OIDC (optional) =====
# OIDC_ENABLED=false
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=xch-app
# OIDC_CLIENT_SECRET=your-oidc-secret
# OIDC_CALLBACK_URL=https://yourdomain.com/api/auth/oidc/callback

# ===== SMTP (Email - optional) =====
# Leave SMTP_HOST empty to log emails to console (dev mode)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@xch.local

# ===== REDIS =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== MINIO (S3-compatible storage) =====
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=xch_minio_admin
# Same value as MINIO_SECRET_KEY in the root .env (compose strict mode requires it).
MINIO_SECRET_KEY=
MINIO_BUCKET=xch-storage
MINIO_USE_SSL=false
# Public URL for browser access to stored files
# When behind nginx: leave empty (uses /storage/ relative path via nginx proxy)
# When direct access needed: http://localhost:9000 (dev) or https://cdn.yourdomain.com
MINIO_PUBLIC_URL=

# ===== STORAGE =====
# Options: minio (recommended), filesystem
STORAGE_TYPE=minio
UPLOAD_DIR=./uploads

# ===== NETBOX INTEGRATION (optional) =====
# NETBOX_URL=https://netbox.example.com
# NETBOX_TOKEN=your_netbox_api_token_here

# Native monitoring (ADR-016) — no env var needed.
# The XCH worker container runs ICMP/HTTP/TCP probes natively, results
# stored in monitor_checks / monitor_results, alerts via NotificationConfig.
# No external Gatus/Uptime Kuma dependency.

# ===== GLITCHTIP / SENTRY OBSERVABILITY (S8 — ADR-024) =====
# Self-hosted GlitchTip air-gap, voir docker-compose.glitchtip.yml.
# DSN backend = adresse INTERNE Docker network (xch-backend et
# xch-backend-worker joignent glitchtip-web sur xch-network). Browser users
# utilisent le DSN public côté frontend (NEXT_PUBLIC_GLITCHTIP_DSN_FRONTEND
# dans frontend/.env).
# Si vide, Sentry.captureException reste no-op silencieux (dev local sans
# GlitchTip = comportement attendu).
# Récupération initiale : `bash glitchtip/scripts/gen-dsn.sh` après déploiement.
# GLITCHTIP_DSN_BACKEND=http://<32hex-public-key>@glitchtip-web:8000/<project_id>
# Override environment tag (défaut: NODE_ENV ou "development").
# GLITCHTIP_ENVIRONMENT=production
# Release tag (souvent injecté en CI : git sha ou tag annoté).
# GLITCHTIP_RELEASE=v2.1.0
