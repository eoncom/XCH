# ===== DATABASE =====
DATABASE_URL="postgresql://xch_user:XchSecure2024!@postgres:5432/xch_dev"

# ===== APP =====
NODE_ENV=development
PORT=3002
APP_URL=http://localhost:3002

# ===== FRONTEND =====
FRONTEND_URL=http://localhost:3001

# ===== CORS =====
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ===== COOKIES =====
# Domain for cookies (leave empty for localhost, set to .yourdomain.com for production)
COOKIE_DOMAIN=

# ===== JWT =====
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ===== OIDC (optional) =====
OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=xch-app
OIDC_CLIENT_SECRET=your-oidc-secret
OIDC_CALLBACK_URL=http://localhost:3002/api/auth/oidc/callback

# ===== REDIS =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== MINIO (S3-compatible storage) =====
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=xch_minio_admin
MINIO_SECRET_KEY=XchMinIO2024SecureKey!
MINIO_BUCKET=xch-storage
MINIO_USE_SSL=false

# ===== STORAGE =====
STORAGE_TYPE=filesystem
UPLOAD_DIR=./uploads

# ===== NETBOX INTEGRATION (optional) =====
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=your_netbox_api_token_here

# ===== UPTIME KUMA INTEGRATION (optional) =====
UPTIME_KUMA_URL=https://uptime.example.com
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=your_password_here
