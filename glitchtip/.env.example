# GlitchTip self-hosted observability — env template (S8 / ADR-024).
#
# Copier en `glitchtip/.env` puis remplir. Le fichier réel est gitignored
# (.gitignore racine line `.env` matche n'importe quelle profondeur).
#
# Génération automatique des 3 secrets (SECRET_KEY / POSTGRES_PASSWORD /
# ADMIN_PASSWORD) :
#
#   bash glitchtip/scripts/gen-secrets.sh > glitchtip/.env
#
# (Le script part de ce template et y injecte les 3 valeurs aléatoires.)
#
# Récupération des 3 DSN (1 par cible) après le premier `up -d` :
#
#   bash glitchtip/scripts/gen-dsn.sh
#
# Le script lit ADMIN_EMAIL/ADMIN_PASSWORD ici, login sur l'API GlitchTip,
# crée org `xch` + 3 projets `xch-backend` / `xch-worker` / `xch-frontend`
# et imprime les 3 DSN à coller dans backend/.env et frontend/.env.

# ---------------------------------------------------------------------------
# Secrets — REMPLIR avant `up -d`. Tous obligatoires (le compose echoue sinon).
# ---------------------------------------------------------------------------

# Django SECRET_KEY (signing cookies, CSRF, etc.). 32 bytes hex minimum.
# Generate: `openssl rand -hex 32`
GLITCHTIP_SECRET_KEY=

# Postgres password du conteneur glitchtip-postgres (réseau interne).
# Generate: `openssl rand -hex 32`
GLITCHTIP_POSTGRES_PASSWORD=

# Compte super-admin auto-seedé au premier `up`. Idempotent (skip si existe).
GLITCHTIP_ADMIN_EMAIL=admin@xch.local
# Generate: `openssl rand -hex 24` (login UI/SSH tunnel only — pas d'usage CLI)
GLITCHTIP_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Réglages — défauts conservateurs, ajuster par environnement.
# ---------------------------------------------------------------------------

# Postgres user/db (n'a pas besoin d'être unique entre envs — réseau privé).
GLITCHTIP_POSTGRES_USER=glitchtip
GLITCHTIP_POSTGRES_DB=glitchtip

# Rétention events. Décision user 2026-05-08 : 90j max, purge auto via
# Celery beat (`cleanup_old_events`).
GLITCHTIP_MAX_EVENT_LIFE_DAYS=90

# Signup public désactivé : seul l'admin auto-seedé peut créer des comptes
# via l'UI (Settings → Members). Mettre à `true` UNIQUEMENT en dev local
# pour bootstrap rapide. NB : nom officiel = ENABLE_USER_REGISTRATION
# (pas ENABLE_OPEN_USER_REGISTRATION qui n'existe pas).
GLITCHTIP_ENABLE_USER_REGISTRATION=false

# Domaine accepté par Django ALLOWED_HOSTS.
# - Dev local            : http://localhost:8000
# - xch-deploy via NPM   : https://glitchtip.eoncom.io
# - Prod air-gap finale  : http://glitchtip-web:8000  (interne uniquement)
GLITCHTIP_DOMAIN=http://glitchtip-web:8000

# Email outbound pour invitations / reset password. Air-gap = consolemail.
# Format Django EMAIL_URL (ex: smtp://user:pass@host:587).
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_FROM_EMAIL=glitchtip@xch.local

# ---------------------------------------------------------------------------
# Réseau XCH (external) — nom dépendant du worktree / project-name compose.
# Déterminer avec `docker network ls | grep xch-network` après avoir démarré
# la stack XCH (`docker compose up -d` sur le compose principal).
#
# Exemples :
#   - worktree dev : relaxed-morse-e92d0e_xch-network
#   - worktree dev : silly-goldwasser-7afb38_xch-network
#   - xch-deploy   : xch_xch-network  (project-name = nom du dossier `xch`)
# ---------------------------------------------------------------------------
XCH_NETWORK_NAME=relaxed-morse-e92d0e_xch-network
