# ===== API BACKEND =====
# When behind nginx (production), leave empty — API calls use relative URLs
# Only set when backend is on a different origin (e.g., direct dev access)
NEXT_PUBLIC_API_URL=

# ===== APP =====
# URL of this frontend application (for Open Graph, canonical URLs, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ===== DEVELOPMENT =====
# Set to 'production' in production environment
NODE_ENV=development

# ===== AUTHENTICATION (Optional - if using OIDC) =====
# NEXT_PUBLIC_OIDC_ISSUER=https://auth.example.com
# NEXT_PUBLIC_OIDC_CLIENT_ID=xch-frontend

# ===== GLITCHTIP / SENTRY OBSERVABILITY (S8 — ADR-024) =====
# Self-hosted GlitchTip — DSN public (browser-reachable via NPM
# https://glitch.eoncom.io). MÊME DSN utilisé pour browser ET SSR Next 15
# (un seul projet GlitchTip `xch-frontend`, facette `runtime` filtre
# browser/ssr/edge côté UI).
# Si vide, Sentry.captureException reste no-op silencieux (dev local).
# Récupération initiale : `bash glitchtip/scripts/gen-dsn.sh` (sortie
# `NEXT_PUBLIC_GLITCHTIP_DSN_FRONTEND=https://...@glitch.eoncom.io/<id>`).
# NEXT_PUBLIC_GLITCHTIP_DSN_FRONTEND=
# Override environment tag (défaut: NODE_ENV ou "development").
# NEXT_PUBLIC_GLITCHTIP_ENVIRONMENT=production
# Release tag (souvent injecté en CI : git sha ou tag annoté).
# NEXT_PUBLIC_GLITCHTIP_RELEASE=v2.1.0
