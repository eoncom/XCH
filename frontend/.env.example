# ===== API BACKEND =====
# When behind nginx (production), leave empty — API calls use relative URLs
# Only set when backend is on a different origin (e.g., direct dev access)
NEXT_PUBLIC_API_URL=

# ===== APP =====
# URL of this frontend application (for Open Graph, canonical URLs, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ===== DEVELOPMENT =====
# Set to 'production' in production environment
NODE_ENV=development

# ===== AUTHENTICATION (Optional - if using OIDC) =====
# NEXT_PUBLIC_OIDC_ISSUER=https://auth.example.com
# NEXT_PUBLIC_OIDC_CLIENT_ID=xch-frontend
