# ===== API BACKEND =====
# URL to the backend API
NEXT_PUBLIC_API_URL=http://localhost:3002

# ===== APP =====
# URL of this frontend application
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ===== DEVELOPMENT =====
# Set to 'production' in production environment
NODE_ENV=development

