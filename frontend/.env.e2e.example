# XCH - Environment Configuration for E2E Tests (Example)
# =======================================================
#
# Copier ce fichier vers .env.e2e et adapter les URLs selon votre environnement
#
# Pour tests locaux:
# PLAYWRIGHT_BASE_URL=http://localhost:3001
# PLAYWRIGHT_API_URL=http://localhost:3002
#
# Pour tests serveur dev (IP directe):
# PLAYWRIGHT_BASE_URL=http://192.168.0.13:3001
# PLAYWRIGHT_API_URL=http://192.168.0.13:3002
#
# Pour tests serveur prod (domaines HTTPS via NPM):
# PLAYWRIGHT_BASE_URL=https://xch.eoncom.io
# PLAYWRIGHT_API_URL=https://xchapi.eoncom.io

# Base URL de l'application frontend (défaut: local)
PLAYWRIGHT_BASE_URL=http://localhost:3001

# API Backend URL (défaut: local)
PLAYWRIGHT_API_URL=http://localhost:3002
